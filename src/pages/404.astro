---
import Layout from "@layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = `${t("notFound.heading")} — ${t("notFound.title")}`;
const description = t("notFound.description");
const home = lang === "es" ? "/" : "/en";
---

<Layout title={title} description={description} lang={lang}>
  <section class="notfound container">
    <p class="notfound__num">404</p>
    <h1 class="notfound__title">{t("notFound.subtitle")}</h1>
    <p class="notfound__desc">{t("notFound.description")}</p>
    <div class="notfound__actions">
      <a href={home} class="btn btn--primary">{t("notFound.homeButton")}</a>
      <button onclick="history.back()" class="btn btn--ghost">← {t("notFound.backButton")}</button>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    padding-top: clamp(80px, 14vw, 160px);
    padding-bottom: clamp(80px, 14vw, 160px);
    max-width: 640px;
  }
  .notfound__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(96px, 22vw, 220px);
    line-height: 0.85;
    color: var(--color-accent);
    margin: 0;
  }
  .notfound__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.05;
    color: var(--color-ink);
    margin: 24px 0 0;
  }
  .notfound__desc {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 16px 0 0;
    max-width: 48ch;
  }
  .notfound__actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 40px; }
</style>
