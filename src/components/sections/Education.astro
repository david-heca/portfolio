---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const academicIcons: Record<string, string> = {
  tesco: "ph:graduation-cap-duotone",
  platzi: "ph:monitor-play-duotone",
  cecytem: "ph:code-duotone",
};

const academic = ["tesco", "platzi", "cecytem"].map((k) => ({
  icon: academicIcons[k],
  year: t(`education.list.${k}.period`),
  degree: t(`education.list.${k}.degree`),
  school: t(`education.list.${k}.institution`),
  note: t(`education.list.${k}.description`),
}));

const certs = [
  { year: "2024", name: t("education.certifications.azure.name"), issuer: "Microsoft", icon: "ph:cloud-duotone", tags: ["Azure", "Cloud", "Security"] },
  { year: "2022", name: t("education.certifications.python.name"), issuer: "U. Michigan · Coursera", icon: "ph:code-duotone", tags: ["Python", "SQL"] },
];

const interests = lang === "es"
  ? ["IA generativa", "MLOps", "Sistemas distribuidos", "Café de especialidad", "Tipografía"]
  : ["Generative AI", "MLOps", "Distributed systems", "Specialty coffee", "Typography"];
---

<section id="education" class="edu section container">
  <header class="sec-head reveal">
    <p class="kicker">{t("nav.education")}</p>
    <h2 class="section-title">{t("education.headerTitle")} <em>{t("education.headerItalic")}</em></h2>
    <p class="lead">{t("education.description")}</p>
  </header>

  <div class="edu__split">
    <div class="edu__col reveal">
      <p class="edu__col-label">{t("education.academicTitle")}</p>
      <div class="edu__list">
        {academic.map((e) => (
          <div class="edu-item">
            <div class="edu-item__aside">
              <Icon name={e.icon} class="edu-item__icon" />
              <span class="edu-item__year">{e.year}</span>
            </div>
            <div>
              <h3 class="edu-item__degree">{e.degree}</h3>
              <p class="edu-item__school">{e.school}</p>
              <p class="edu-item__note">{e.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="edu__col reveal reveal-1">
      <p class="edu__col-label">{t("education.certsTitle")}</p>
      <div class="edu__list">
        {certs.map((c) => (
          <div class="cert">
            <div class="cert__head">
              <span class="cert__lead">
                <Icon name={c.icon} class="cert__icon" />
                <h3 class="cert__name">{c.name}</h3>
              </span>
              <span class="cert__year">{c.year}</span>
            </div>
            <p class="cert__issuer">{c.issuer}</p>
            <div class="cert__tags">{c.tags.map((tg) => <span class="tag">{tg}</span>)}</div>
          </div>
        ))}
      </div>

      <div class="edu__extra">
        <div>
          <p class="edu__col-label">{t("education.languagesTitle")}</p>
          <p class="edu__langs">
            {lang === "es" ? "Español — Nativo" : "Spanish — Native"}<br />
            {lang === "es" ? "Inglés — Profesional" : "English — Professional"}
          </p>
        </div>
        <div>
          <p class="edu__col-label">{t("education.interestsTitle")}</p>
          <div class="cert__tags">{interests.map((i) => <span class="tag">{i}</span>)}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sec-head { max-width: 720px; margin-bottom: 56px; }
  .sec-head .lead { margin-top: 20px; }

  .edu__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  @media (min-width: 900px) { .edu__split { grid-template-columns: 1fr 1fr; gap: 64px; } }

  .edu__col-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 24px;
  }

  .edu__list { display: flex; flex-direction: column; gap: 32px; }

  .edu-item { display: grid; grid-template-columns: 1fr; gap: 4px; }
  @media (min-width: 480px) { .edu-item { grid-template-columns: 110px 1fr; gap: 20px; } }
  .edu-item__aside {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    padding-top: 3px;
  }
  @media (min-width: 480px) { .edu-item__aside { flex-direction: column; align-items: flex-start; gap: 8px; } }
  .edu-item__icon { font-size: 26px; color: var(--color-accent); }
  .edu-item__year {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.04em;
    color: var(--color-ink-2);
  }
  .edu-item__degree {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }
  .edu-item__school {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.02em;
    color: var(--color-ink-2);
    margin: 6px 0 0;
  }
  .edu-item__note {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-ink-2);
    margin: 10px 0 0;
  }

  .cert { padding-bottom: 28px; border-bottom: 1px solid var(--color-line); }
  .cert:last-child { border-bottom: 0; padding-bottom: 0; }
  .cert__head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .cert__lead { display: flex; align-items: center; gap: 11px; min-width: 0; }
  .cert__icon { font-size: 24px; color: var(--color-accent); }
  .cert__name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0;
  }
  .cert__year {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--color-ink-3);
    flex-shrink: 0;
  }
  .cert__issuer {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--color-ink-2);
    margin: 6px 0 12px;
  }
  .cert__tags { display: flex; flex-wrap: wrap; gap: 7px; }

  .edu__extra {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--color-line);
  }
  .edu__langs {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    line-height: 1.5;
    color: var(--color-ink);
    margin: 0;
  }
</style>
