---
import { useTranslations } from "@i18n/utils";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Item {
  year: string;
  title: string;
  place: string;
  desc: string;
}

const items: Item[] = [
  {
    year: t("education.list.tesco.period"),
    title: t("education.list.tesco.degree"),
    place: t("education.list.tesco.institution"),
    desc: t("education.list.tesco.description"),
  },
  {
    year: t("education.list.platzi.period"),
    title: t("education.list.platzi.degree"),
    place: t("education.list.platzi.institution"),
    desc: t("education.list.platzi.description"),
  },
  {
    year: t("education.list.cecytem.period"),
    title: t("education.list.cecytem.degree"),
    place: t("education.list.cecytem.institution"),
    desc: t("education.list.cecytem.description"),
  },
  {
    year: "2024",
    title: t("education.certifications.azure.name"),
    place: "Microsoft · " + t("education.labels.featured"),
    desc: "Azure · Cloud Computing · Networking · Security",
  },
  {
    year: "2022",
    title: t("education.certifications.python.name"),
    place: "Michigan University · Coursera",
    desc: "Python · Data Structures · SQL",
  },
];

const headingHtml = t("education.heading");
---

<section class="edu container-editorial">
  <div class="reveal section-label">// 03. {t("nav.education")}</div>
  <h1 class="reveal reveal-delay-1 edu__h" set:html={headingHtml}></h1>
  <p class="reveal reveal-delay-2 work__sub">{t("education.description")}</p>

  <div class="edu__grid">
    <div>
      {items.map((it, i) => (
        <div class={`timeline__item reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <div class="timeline__year">{it.year}</div>
          <div>
            <div class="timeline__title">{it.title}</div>
            <div class="timeline__place">{it.place}</div>
            <div class="timeline__desc">{it.desc}</div>
          </div>
        </div>
      ))}
    </div>
    <aside>
      <div class="side-card reveal">
        <div class="side-card__k">{t("education.sideCards.languagesTitle")}</div>
        <div class="side-card__v" set:html={t("education.sideCards.languagesBody")}></div>
      </div>
      <div class="side-card reveal reveal-delay-1">
        <div class="side-card__k">{t("education.sideCards.interestsTitle")}</div>
        <div class="side-card__v">{t("education.sideCards.interestsBody")}</div>
      </div>
      <div class="side-card reveal reveal-delay-2">
        <div class="side-card__k">{t("education.sideCards.philosophyTitle")}</div>
        <div class="side-card__v" set:html={t("education.sideCards.philosophyBody")}></div>
      </div>
    </aside>
  </div>
</section>

<PageFooter lang={lang} num="03" />
