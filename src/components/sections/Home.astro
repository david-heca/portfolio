---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const creditsRows = ["backend", "frontend", "cloud", "ai"] as const;

// Tecnologías clave que se resaltan (accent) en el "output" del terminal
const stackHighlight = new Set([".NET", "Python", "Azure", "LLMs", "RAG", "MCP", "MLOps"]);

const aboutHeadingHtml = t("home.aboutSection.heading");
const bio1Html = t("home.aboutSection.bio.paragraph1");
const bio2Html = t("home.aboutSection.bio.paragraph2");
const bio3Html = t("home.aboutSection.bio.paragraph3");
---

<section class="hero container-editorial">
  <div class="hero__split">
    <!-- LEFT — typography column -->
    <div class="hero__left">
      <div class="hero__topline reveal">
        <span class="label accent">— 00 / {t("nav.home")}</span>
      </div>

      <div style="position: relative;">
        <div class="hero__greeting reveal reveal-delay-1 mb-8!">
          <Icon name="ph:hand-waving-duotone" />
          <span class="hand lg">
            {t("hero.greeting")}<span style="color: var(--color-accent);">—</span>
          </span>
          <span class="label" style="margin-left: 6px;">{t("hero.greetingTail")}</span>
        </div>

        <h1 class="hero__name reveal reveal-delay-1">
          <span class="hero__name-line1">David</span>
          <span class="hero__name-line2">
            Herrera<span class="accent-dot">.</span>
          </span>
        </h1>

        <div class="hero__tagline reveal reveal-delay-2">
          <div class="hero__tagline-line">
            <Icon name="ph:circuitry-duotone" />
            <b>{t("hero.tagline.role1")}</b>
            <span style="color: var(--color-ink-2);">✼</span>
            <b class="accent">{t("hero.tagline.role2")}</b>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-4" style="padding-bottom: 8px;">
        <div class="hero__ctas">
          <a
            href={lang === "es" ? "/projects" : "/en/projects"}
            class="chip accent"
            data-astro-prefetch="hover"
          >
            <Icon name="ph:arrow-up-right-duotone" />
            {t("hero.ctas.work")}
          </a>
          <a href={`mailto:hello@davidherrera.dev`} class="chip">
            <Icon name="ph:envelope-simple-duotone" />
            {t("hero.ctas.email")}
          </a>
        </div>
        <div class="hero__metarow meta-row">
          <span class="icon-row"><Icon name="ph:map-pin-duotone" />{t("hero.metaBar.city")}</span>
          <span class="sep">/</span>
          <span class="icon-row"><Icon name="ph:clock-duotone" />GMT-6</span>
          <span class="sep">/</span>
          <span class="icon-row" style="color: var(--color-accent);">
            <span class="pulse"></span>
            {t("hero.metaBar.status")} · {t("hero.metaBar.statusFor")}
          </span>
        </div>
      </div>

    </div>

    <!-- RIGHT — bento stack -->
    <div class="hero__right">
      <div class="hero__portrait reveal">
        <div class="placeholder">
          <Image
            src="/assets/profile-photo.webp"
            alt="David Herrera"
            width={400}
            height={533}
            loading="eager"
            format="webp"
            quality={85}
          />
        </div>
        <div class="sticker hero__portrait-sticker">
          <Icon name="ph:flag-duotone" />
          {t("hero.sticker")}
        </div>
      </div>

      <div class="box accent hero__currently reveal reveal-delay-1">
        <div class="hero__currently-head">
          <div class="icon-row">
            <span class="pulse"></span>
            <span class="label accent">// {t("hero.currently.label")}</span>
          </div>
          <Icon name="ph:plugs-connected-duotone" />
        </div>
        <div class="hero__currently-text">
          {t("hero.currently.text")}
        </div>
      </div>

      <div class="box hero__socials reveal reveal-delay-2">
        <div class="icon-row">
          <a href="https://github.com/david-heca" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <Icon name="ph:github-logo-duotone" />
          </a>
          <a href="https://www.linkedin.com/in/david-heca/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <Icon name="ph:linkedin-logo-duotone" />
          </a>
          <a href="https://x.com/david_heca_" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
            <Icon name="ph:x-logo-duotone" />
          </a>
          <a href={`mailto:hello@davidherrera.dev`} aria-label="Email">
            <Icon name="ph:envelope-simple-duotone" />
          </a>
        </div>
        <span class="hand sm accent">
          <span style="display: inline-flex; align-items: center; gap: 6px;">
            scroll
            <Icon name="ph:arrow-down-duotone" style="font-size: 14px;" />
          </span>
        </span>
      </div>
    </div>
  </div>
</section>

<section class="home-about container-editorial">
  <div class="home-about__intro">
    <div class="reveal label accent">// {t("home.aboutSection.title")}</div>
    <h2 class="reveal reveal-delay-1 home-about__title" set:html={aboutHeadingHtml}></h2>
  </div>
  <div class="home-about__body">
    <p class="reveal reveal-delay-2" set:html={bio1Html}></p>
    <p class="reveal reveal-delay-3" set:html={bio2Html}></p>
    <p class="reveal reveal-delay-4" set:html={bio3Html}></p>
  </div>
</section>

<section class="home-credits container-editorial">
  <div class="reveal label accent">// {t("home.credits.label")}</div>
  <div class="terminal reveal">
    <div class="terminal__bar">
      <span class="terminal__dots" aria-hidden="true"><i></i><i></i><i></i></span>
      <span class="terminal__title">{t("home.credits.title")}</span>
      <span class="terminal__shell" aria-hidden="true">zsh</span>
    </div>
    <div class="terminal__body">
      <div class="terminal__cmdline">
        <span class="terminal__user">david@portfolio</span>
        <span class="terminal__path">~</span>
        <span class="terminal__sym">%</span>
        <span class="terminal__cmd">{t("home.credits.command")}</span>
        <span class="terminal__caret" aria-hidden="true"></span>
      </div>
      {creditsRows.map((key) => {
        const items = (t(`home.credits.rows.${key}.items`) as string)
          .split("·")
          .map((s: string) => s.trim())
          .filter(Boolean);
        return (
          <div class="terminal__row">
            <span class="terminal__arrow" aria-hidden="true">›</span>
            <span class="terminal__key">{t(`home.credits.rows.${key}.label`)}</span>
            <span class="terminal__val">
              {items.map((tok: string, j: number) => (
                <>
                  {j > 0 && <span class="terminal__sep" aria-hidden="true">·</span>}
                  <span class={`terminal__tok${stackHighlight.has(tok) ? " is-key" : ""}`}>{tok}</span>
                </>
              ))}
            </span>
          </div>
        );
      })}
    </div>
  </div>
</section>

<PageFooter lang={lang} num="00" />

<style>
  /* hero — editorial split */
  .hero {
    position: relative;
    padding-top: 28px;
    padding-bottom: 24px;
  }
  .hero__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: stretch;
    position: relative;
  }
  .hero__split > * { min-width: 0; }
  @media (min-width: 1024px) {
    .hero__split {
      grid-template-columns: 1.45fr 1fr;
      gap: 48px;
      min-height: 720px;
    }
  }

  .hero__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
    padding-top: 14px;
    position: relative;
  }

  .hero__topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .hero__greeting {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .hero__greeting [data-icon] {
    font-size: 28px;
    color: var(--color-accent);
  }

  .hero__name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.84;
    color: var(--color-ink);
    margin: 0;
  }
  .hero__name-line1,
  .hero__name-line2 {
    display: block;
    font-size: clamp(56px, 14vw, 168px);
  }
  .hero__name-line2 {
    margin-left: clamp(12px, 4vw, 56px);
    position: relative;
  }
  .hero__name-line2 .accent-dot {
    color: var(--color-accent);
    font-style: normal;
  }

  .hero__tagline {
    margin-top: 32px;
    max-width: 560px;
    font-size: var(--text-lead);
    line-height: 1.6;
    color: var(--color-ink);
  }
  .hero__tagline-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .hero__tagline-line [data-icon] {
    font-size: 16px;
    color: var(--color-accent);
  }
  .hero__tagline-line b { font-weight: 500; }
  .hero__tagline-line .accent { font-weight: 500; color: var(--color-accent); }

  .hero__ctas {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .hero__ctas .chip { padding: 7px 14px; gap: 6px; font-size: 11px; }
  .hero__ctas .chip [data-icon] { font-size: 14px; color: var(--color-accent); }

  .hero__metarow {
    display: flex;
    gap: 12px 18px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero__metarow .sep { display: none; }
  @media (min-width: 640px) {
    .hero__metarow .sep { display: inline; }
  }

  .hero__right {
    display: grid;
    grid-template-rows: auto;
    gap: 12px;
    position: relative;
    padding-top: 6px;
  }
  @media (min-width: 1024px) {
    .hero__right {
      grid-template-rows: 1fr auto auto;
    }
  }

  .hero__portrait {
    position: relative;
    overflow: visible;
    min-height: 320px;
    aspect-ratio: 4 / 5;
  }
  @media (min-width: 1024px) {
    .hero__portrait { aspect-ratio: auto; min-height: 0; }
  }
  .hero__portrait .placeholder {
    position: absolute;
    inset: 0;
    border-radius: 6px;
  }
  /* .hero__portrait-stamp cae sobre la raíz del componente hijo <Stamp>,
     que no hereda el scope de Home; se ancla vía .hero__portrait (sí scoped)
     + :global() para alcanzarlo y ganarle en especificidad a .stamp. */
  .hero__portrait :global(.hero__portrait-stamp) {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero__portrait :global(.hero__portrait-stamp) {
      display: flex;
      top: -28px;
      right: -28px;
      transform: rotate(8deg);
      z-index: 3;
    }
  }
  .hero__portrait-sticker {
    bottom: 14px;
    left: 14px;
    transform: rotate(-3deg);
    z-index: 2;
  }

  .hero__currently {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px 18px;
  }
  .hero__currently-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .hero__currently-head [data-icon] {
    font-size: 22px;
    color: var(--color-accent);
  }
  .hero__currently-text {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink);
  }

  .hero__socials {
    padding: 10px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .hero__socials .icon-row { gap: 14px; }
  .hero__socials a {
    display: inline-flex;
    align-items: center;
    color: var(--color-ink);
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .hero__socials a:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }
  .hero__socials a [data-icon] { font-size: 17px; }

  /* portrait sticker */
  .sticker {
    position: absolute;
    font-family: var(--font-hand);
    font-size: 17px;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 5px 14px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .sticker [data-icon] { font-size: 14px; color: var(--color-bg); }

  /* about */
  .home-about {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-top: 64px;
    padding-bottom: 64px;
  }
  @media (min-width: 1024px) {
    .home-about {
      grid-template-columns: 1fr 1.2fr;
      gap: 64px;
      align-items: start;
    }
  }
  .home-about__intro {
    align-self: start;
  }
  @media (min-width: 1024px) {
    .home-about__intro {
      position: sticky;
      top: 96px;
    }
  }
  .home-about__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.92;
    font-size: clamp(36px, 6vw, 72px);
    color: var(--color-ink);
    margin: 16px 0 0;
  }
  .home-about__title em {
    color: var(--color-accent);
    font-style: italic;
  }
  .home-about__body p {
    font-size: var(--text-lead);
    line-height: var(--leading-prose);
    max-width: var(--measure);
    color: var(--color-ink);
    margin: 0 0 18px;
  }
  .home-about__body strong {
    font-weight: 500;
    color: var(--color-ink);
    border-bottom: 1.5px solid var(--color-accent);
    padding-bottom: 1px;
  }

  /* credits */
  .home-credits {
    padding-top: 32px;
    padding-bottom: 64px;
  }
  /* terminal — faux CLI session */
  .terminal {
    margin-top: 18px;
    max-width: 760px;
    border: var(--line) solid var(--color-line-strong);
    border-radius: 8px;
    background: var(--color-bg-2);
    overflow: hidden;
    font-family: var(--font-mono);
  }
  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: var(--line) solid var(--color-line);
    background: color-mix(in srgb, var(--color-ink) 4%, transparent);
  }
  .terminal__dots { display: inline-flex; gap: 6px; }
  .terminal__dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-ink-3);
    display: block;
  }
  .terminal__dots i:first-child { background: var(--color-accent); }
  .terminal__title {
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--color-ink-2);
  }
  .terminal__shell {
    margin-left: auto;
    font-size: 10px;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  .terminal__body {
    padding: 18px;
    font-size: var(--text-body);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .terminal__cmdline {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .terminal__user { color: var(--color-accent); }
  .terminal__path { color: var(--color-ink-2); }
  .terminal__sym { color: var(--color-ink-3); }
  .terminal__cmd { color: var(--color-ink); font-weight: 500; }
  .terminal__caret {
    width: 8px;
    height: 15px;
    background: var(--color-accent);
    display: inline-block;
    transform: translateY(2px);
    animation: terminal-blink 1.1s steps(1) infinite;
  }
  @keyframes terminal-blink {
    0%, 50% { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }
  .terminal__row {
    display: grid;
    grid-template-columns: 16px 104px 1fr;
    gap: 10px;
    align-items: baseline;
  }
  .terminal__arrow { color: var(--color-accent); }
  .terminal__key {
    color: var(--color-ink-2);
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }
  .terminal__sep { color: var(--color-ink-3); margin: 0 6px; }
  .terminal__tok { color: var(--color-ink); }
  .terminal__tok.is-key { color: var(--color-accent); font-weight: 500; }
  .terminal__check { color: var(--color-accent); }
  @media (max-width: 520px) {
    .terminal__body { padding: 16px 14px; }
    .terminal__row { grid-template-columns: 14px 76px 1fr; gap: 8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .terminal__caret { animation: none; }
  }
</style>
