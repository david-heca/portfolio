---
import { Image } from "astro:assets";
import { useTranslations } from "@i18n/utils";
import TechRing from "@ui/TechRing.astro";
import MetaBar from "@ui/MetaBar.astro";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const creditsRows = ["backend", "frontend", "cloud", "ai"] as const;

const roleHtml = t("hero.role");
const aboutHeadingHtml = t("home.aboutSection.heading");
const bio1Html = t("home.aboutSection.bio.paragraph1");
const bio2Html = t("home.aboutSection.bio.paragraph2");
const bio3Html = t("home.aboutSection.bio.paragraph3");
---

<section class="hero container-editorial">
  <MetaBar lang={lang} />
  <TechRing lang={lang} />

  <div class="reveal hero__intro">
    <span class="live" aria-hidden="true"></span>
    {t("hero.greeting")}<span style="color: var(--color-ink);">&nbsp;—</span>
  </div>

  <h1 class="reveal reveal-delay-1 hero__name">
    David<br />Herrer<span class="amp">a</span>
  </h1>

  <div class="hero__tagrow">
    <div class="reveal reveal-delay-2 hero__role" set:html={roleHtml}></div>
    <p class="reveal reveal-delay-3 hero__desc">{t("hero.shortDesc")}</p>
  </div>
</section>

<div class="stats container-editorial">
  <div class="stat">
    <div class="stat__num">4<span class="plus">+</span></div>
    <div class="stat__label">{t("home.stats.experience")}</div>
  </div>
  <div class="stat">
    <div class="stat__num">20<span class="plus">+</span></div>
    <div class="stat__label">{t("home.stats.projects")}</div>
  </div>
  <div class="stat">
    <div class="stat__num">10</div>
    <div class="stat__label">{t("home.stats.techs")}</div>
  </div>
  <div class="stat">
    <div class="stat__num">∞</div>
    <div class="stat__label">{t("home.stats.drive")}</div>
  </div>
</div>

<section class="about container-editorial">
  <div class="reveal about__photo about__photo-corners">
    <Image
      src="/assets/profile-photo.webp"
      alt="David Herrera"
      width={400}
      height={533}
      loading="eager"
      format="webp"
      quality={85}
    />
  </div>
  <div>
    <div class="reveal section-label">// {t("home.aboutSection.title")}</div>
    <h2 class="reveal reveal-delay-1 about__title" set:html={aboutHeadingHtml}></h2>
    <div class="about__body">
      <p class="reveal reveal-delay-2" set:html={bio1Html}></p>
      <p class="reveal reveal-delay-3" set:html={bio2Html}></p>
      <p class="reveal reveal-delay-4" set:html={bio3Html}></p>
    </div>
  </div>
</section>

<section class="credits container-editorial">
  <div class="reveal section-label">// {t("home.credits.label")}</div>
  <dl class="credits__list">
    {creditsRows.map((key, i) => (
      <div class={`credits__row reveal reveal-delay-${i + 1}`}>
        <dt class="credits__term">{t(`home.credits.rows.${key}.label`)}</dt>
        <dd class="credits__items">{t(`home.credits.rows.${key}.items`)}</dd>
      </div>
    ))}
  </dl>
</section>

<div class="now-strip footer__inner">
  <div class="now-strip__label">{t("home.nowStrip.label")}</div>
  <div>{t("home.nowStrip.stack")}</div>
</div>

<PageFooter lang={lang} num="00" />
