---
import { Image } from "astro:assets";
import { useTranslations } from "@i18n/utils";
import {
  PiArrowRightBold,
  PiBriefcase,
  PiFolderOpen,
  PiUserCircle,
} from "react-icons/pi";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const getCategory = (category: string) => {
  const categoryMap: Record<string, string> = {
    Backend: t("skills.categories.backend"),
    Frontend: t("skills.categories.frontend"),
    DevOps: t("skills.categories.devops"),
    Cloud: t("skills.categories.cloud"),
    Database: t("skills.categories.database"),
    Tools: t("skills.categories.tools"),
  };
  return categoryMap[category] || category;
};

const getLevel = (level: string) => {
  const levelMap: Record<string, string> = {
    Basic: t("skills.levels.basic"),
    Intermediate: t("skills.levels.intermediate"),
    Advanced: t("skills.levels.advanced"),
  };
  return levelMap[level] || level;
};

const getLevelColor = (level: string) => {
  if (level === t("skills.levels.advanced")) return "#10B981";
  if (level === t("skills.levels.intermediate")) return "var(--color-accent)";
  return "var(--color-text-tertiary)";
};

const primarySkills = [
  { name: "C#", category: getCategory("Backend"), level: getLevel("Intermediate"), icon: "csharp" },
  { name: "Python", category: getCategory("Backend"), level: getLevel("Intermediate"), icon: "python" },
  { name: "JavaScript", category: getCategory("Frontend"), level: getLevel("Intermediate"), icon: "javascript" },
  { name: "React", category: getCategory("Frontend"), level: getLevel("Basic"), iconLight: "https://svgl.app/library/react_light.svg", iconDark: "https://svgl.app/library/react_dark.svg" },
  { name: "Tailwind CSS", category: getCategory("Frontend"), level: getLevel("Intermediate"), icon: "tailwindcss" },
  { name: "Azure", category: getCategory("Cloud"), level: getLevel("Intermediate"), icon: "azure" },
  { name: "Docker", category: getCategory("DevOps"), level: getLevel("Basic"), icon: "docker" },
  { name: "SQL", category: getCategory("Database"), level: getLevel("Intermediate"), icon: "sql-server" },
  { name: "PostgreSQL", category: getCategory("Database"), level: getLevel("Intermediate"), icon: "postgresql" },
  { name: "Git", category: getCategory("Tools"), level: getLevel("Advanced"), icon: "git" },
];
---

<section>
  <div class="space-y-8 md:space-y-12">
    <!-- Hero Section - Cinematic Full Width -->
    <div class="relative overflow-hidden">
      <div
        class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8 md:gap-12 py-8 md:py-16"
      >
        <!-- Text Content -->
        <div class="flex-1 min-w-0">
          <!-- Greeting Label -->
          <p
            class="reveal reveal-delay-1 font-mono text-sm uppercase tracking-widest mb-4"
            style={`color: var(--color-text-tertiary);`}
          >
            {t("hero.greeting")}
          </p>

          <!-- Name -->
          <h1
            class="reveal reveal-delay-2 text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[1.05] mb-6"
          >
            <span class="text-gradient">David Herrera</span>
          </h1>

          <!-- Role -->
          <p
            class="reveal reveal-delay-3 text-xl md:text-2xl leading-relaxed mb-3"
            style={`color: var(--color-text-secondary);`}
          >
            {t("hero.title")}
          </p>
          <p
            class="reveal reveal-delay-4 text-base md:text-lg"
            style={`color: var(--color-text-tertiary);`}
          >
            {t("hero.description")}
          </p>
        </div>

        <!-- Photo -->
        <div class="reveal reveal-delay-3">
          <div class="relative w-72 h-72">
            <Image
              src="/assets/profile-photo.webp"
              alt="David Herrera"
              width={256}
              height={256}
              class="w-full h-full object-cover rounded-3xl"
              loading="eager"
              format="webp"
              quality={85}
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="divider"></div>

    <!-- About Me -->
    <div class="reveal">
      <span
        class="font-mono text-xs uppercase tracking-widest block mb-6"
        style={`color: var(--color-accent);`}
      >
        // {t("home.aboutSection.title")}
      </span>

      <div class="space-y-4 max-w-4xl">
        <p
          class="text-base md:text-lg leading-relaxed"
          style={`color: var(--color-text-secondary);`}
        >
          {t("home.aboutSection.bio.paragraph1")}
        </p>
        <p
          class="text-base md:text-lg leading-relaxed"
          style={`color: var(--color-text-secondary);`}
        >
          {t("home.aboutSection.bio.paragraph2")}
        </p>
        <p
          class="text-base md:text-lg leading-relaxed"
          style={`color: var(--color-text-secondary);`}
        >
          {t("home.aboutSection.bio.paragraph3")}
        </p>
      </div>
    </div>

    <!-- Skills -->
    <div class="reveal">
      <span
        class="font-mono text-xs uppercase tracking-widest block mb-6"
        style={`color: var(--color-accent);`}
      >
        // {t("skills.sections.technologies")}
      </span>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
        {
          primarySkills.map((skill, index) => (
            <div
              class="group/skill p-3 rounded-xl transition-all duration-300 hover-card"
              style={`background-color: var(--color-bg-secondary); border: 1px solid var(--color-border-default);`}
            >
              <div class="flex items-center gap-3 mb-2">
                {skill.icon ? (
                  <Image
                    src={`https://svgl.app/library/${skill.icon}.svg`}
                    alt={`${skill.name} icon`}
                    width={24}
                    height={24}
                    class="w-5 h-5 object-contain shrink-0"
                    loading="lazy"
                  />
                ) : skill.iconLight && skill.iconDark ? (
                  <>
                    <Image
                      src={skill.iconLight}
                      alt={`${skill.name} icon`}
                      width={24}
                      height={24}
                      class="w-5 h-5 object-contain dark:hidden shrink-0"
                      loading="lazy"
                    />
                    <Image
                      src={skill.iconDark}
                      alt={`${skill.name} icon`}
                      width={24}
                      height={24}
                      class="w-5 h-5 object-contain hidden dark:block shrink-0"
                      loading="lazy"
                    />
                  </>
                ) : null}
                <h3
                  class="text-sm font-medium truncate"
                  style={`color: var(--color-text-primary);`}
                >
                  {skill.name}
                </h3>
              </div>
              <div class="flex items-center justify-between">
                <span
                  class="font-mono text-xs"
                  style={`color: var(--color-text-tertiary);`}
                >
                  {skill.category}
                </span>
                <span
                  class="w-2 h-2 rounded-full shrink-0"
                  style={`background-color: ${getLevelColor(skill.level)};`}
                  title={skill.level}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- CTA Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
      <a
        href={lang === "es" ? "/work" : "/en/work"}
        class="reveal reveal-delay-1 group rounded-2xl p-6 border-l-2 transition-all duration-300 hover:-translate-y-0.5 hover-card"
        style={`background-color: var(--color-bg-secondary); border: 1px solid var(--color-border-default);`}
      >
        <div class="flex items-start justify-between mb-3">
          <PiBriefcase className="w-5 h-5 text-zinc-500 dark:text-zinc-400" />
          <PiArrowRightBold
            className="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all text-cyan-500 dark:text-cyan-400"
          />
        </div>
        <h3
          class="text-lg font-semibold mb-1"
          style={`color: var(--color-text-primary);`}
        >
          {t("work.title")}
        </h3>
        <p class="text-sm" style={`color: var(--color-text-tertiary);`}>
          {t("work.subtitle")}
        </p>
      </a>

      <a
        href={lang === "es" ? "/projects" : "/en/projects"}
        class="reveal reveal-delay-2 group rounded-2xl p-6 border-l-2 transition-all duration-300 hover:-translate-y-0.5 hover-card"
        style={`background-color: var(--color-bg-secondary); border: 1px solid var(--color-border-default);`}
      >
        <div class="flex items-start justify-between mb-3">
          <PiFolderOpen
            className="w-5 h-5 text-cyan-500 dark:text-cyan-400"
          />
          <PiArrowRightBold
            className="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all text-cyan-500 dark:text-cyan-400"
          />
        </div>
        <h3
          class="text-lg font-semibold mb-1"
          style={`color: var(--color-text-primary);`}
        >
          {t("projects.title")}
        </h3>
        <p class="text-sm" style={`color: var(--color-text-tertiary);`}>
          {t("projects.subtitle")}
        </p>
      </a>

      <a
        href={lang === "es" ? "/contact" : "/en/contact"}
        class="reveal reveal-delay-3 group rounded-2xl p-6 border-l-2 transition-all duration-300 hover:-translate-y-0.5 hover-card"
        style={`background-color: var(--color-bg-secondary); border: 1px solid var(--color-border-default);`}
      >
        <div class="flex items-start justify-between mb-3">
          <PiUserCircle className="w-5 h-5 text-cyan-500 dark:text-cyan-400" />
          <PiArrowRightBold
            className="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all text-cyan-500 dark:text-cyan-400"
          />
        </div>
        <h3
          class="text-lg font-semibold mb-1"
          style={`color: var(--color-text-primary);`}
        >
          {t("contact.title")}
        </h3>
        <p class="text-sm" style={`color: var(--color-text-tertiary);`}>
          {t("contact.subtitle")}
        </p>
      </a>
    </div>

  </div>
</section>
