---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Stamp from "@ui/Stamp.astro";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const creditsRows = ["backend", "frontend", "cloud", "ai"] as const;

const aboutHeadingHtml = t("home.aboutSection.heading");
const bio1Html = t("home.aboutSection.bio.paragraph1");
const bio2Html = t("home.aboutSection.bio.paragraph2");
const bio3Html = t("home.aboutSection.bio.paragraph3");
---

<section class="hero container-editorial">
  <div class="hero__split">
    <!-- LEFT — typography column -->
    <div class="hero__left">
      <div class="hero__topline reveal">
        <span class="label accent">— 00 / {t("nav.home")}</span>
      </div>

      <div style="position: relative;">
        <div class="hero__greeting reveal reveal-delay-1 mb-8!">
          <Icon name="ph:hand-waving-duotone" />
          <span class="hand lg">
            {t("hero.greeting")}<span style="color: var(--color-accent);">—</span>
          </span>
          <span class="label" style="margin-left: 6px;">{t("hero.greetingTail")}</span>
        </div>

        <h1 class="hero__name reveal reveal-delay-1">
          <span class="hero__name-line1">David</span>
          <span class="hero__name-line2">
            Herrera<span class="accent-dot">.</span>
          </span>
        </h1>

        <div class="hero__tagline reveal reveal-delay-2">
          <div class="hero__tagline-line">
            <Icon name="ph:circuitry-duotone" />
            <b>{t("hero.tagline.role1")}</b>
            <span style="color: var(--color-ink-2);">✼</span>
            <b class="accent">{t("hero.tagline.role2")}</b>
          </div>
        </div>
      </div>

      <div class="reveal reveal-delay-4" style="padding-bottom: 8px;">
        <div class="hero__ctas">
          <a
            href={lang === "es" ? "/projects" : "/en/projects"}
            class="chip accent"
            data-astro-prefetch="hover"
          >
            <Icon name="ph:arrow-up-right-duotone" />
            {t("hero.ctas.work")}
          </a>
          <a href={`mailto:hello@davidherrera.dev`} class="chip">
            <Icon name="ph:envelope-simple-duotone" />
            {t("hero.ctas.email")}
          </a>
        </div>
        <div class="hero__metarow meta-row">
          <span class="icon-row"><Icon name="ph:map-pin-duotone" />{t("hero.metaBar.city")}</span>
          <span class="sep">/</span>
          <span class="icon-row"><Icon name="ph:clock-duotone" />GMT-6</span>
          <span class="sep">/</span>
          <span class="icon-row" style="color: var(--color-accent);">
            <span class="pulse"></span>
            {t("hero.metaBar.status")} · {t("hero.metaBar.statusFor")}
          </span>
        </div>
      </div>

    </div>

    <!-- RIGHT — bento stack -->
    <div class="hero__right">
      <div class="hero__portrait reveal">
        <div class="placeholder">
          <Image
            src="/assets/profile-photo.webp"
            alt="David Herrera"
            width={400}
            height={533}
            loading="eager"
            format="webp"
            quality={85}
          />
        </div>
        <Stamp lang={lang} className="hero__portrait-stamp" />
        <div class="sticker hero__portrait-sticker">
          <Icon name="ph:flag-duotone" />
          {t("hero.sticker")}
        </div>
      </div>

      <div class="box accent hero__currently reveal reveal-delay-1">
        <div class="hero__currently-head">
          <div class="icon-row">
            <span class="pulse"></span>
            <span class="label accent">// {t("hero.currently.label")}</span>
          </div>
          <Icon name="ph:plugs-connected-duotone" />
        </div>
        <div class="hero__currently-text">
          {t("hero.currently.text")}
        </div>
      </div>

      <div class="box hero__socials reveal reveal-delay-2">
        <div class="icon-row">
          <a href="https://github.com/david-heca" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <Icon name="ph:github-logo-duotone" />
          </a>
          <a href="https://www.linkedin.com/in/david-heca/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <Icon name="ph:linkedin-logo-duotone" />
          </a>
          <a href="https://x.com/david_heca_" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
            <Icon name="ph:x-logo-duotone" />
          </a>
          <a href={`mailto:hello@davidherrera.dev`} aria-label="Email">
            <Icon name="ph:envelope-simple-duotone" />
          </a>
        </div>
        <span class="hand sm accent">
          <span style="display: inline-flex; align-items: center; gap: 6px;">
            scroll
            <Icon name="ph:arrow-down-duotone" style="font-size: 14px;" />
          </span>
        </span>
      </div>
    </div>
  </div>
</section>

<section class="home-about container-editorial">
  <div class="home-about__intro">
    <div class="reveal label accent">// {t("home.aboutSection.title")}</div>
    <h2 class="reveal reveal-delay-1 home-about__title" set:html={aboutHeadingHtml}></h2>
  </div>
  <div class="home-about__body">
    <p class="reveal reveal-delay-2" set:html={bio1Html}></p>
    <p class="reveal reveal-delay-3" set:html={bio2Html}></p>
    <p class="reveal reveal-delay-4" set:html={bio3Html}></p>
  </div>
</section>

<section class="home-credits container-editorial">
  <div class="reveal label accent">// {t("home.credits.label")}</div>
  <dl class="home-credits__list">
    {creditsRows.map((key, i) => (
      <div class={`home-credits__row reveal reveal-delay-${i + 1}`}>
        <dt class="home-credits__term">{t(`home.credits.rows.${key}.label`)}</dt>
        <dd class="home-credits__items">{t(`home.credits.rows.${key}.items`)}</dd>
      </div>
    ))}
  </dl>
</section>

<PageFooter lang={lang} num="00" />
