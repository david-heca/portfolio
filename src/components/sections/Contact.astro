---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import PageHeader from "@ui/PageHeader.astro";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const email = "hello@davidherrera.dev";

const elsewhere = [
  { k: "github", v: "@david-heca", href: "https://github.com/david-heca" },
  { k: "linkedin", v: "in/david-heca", href: "https://www.linkedin.com/in/david-heca/" },
  { k: "x / twitter", v: "@david_heca_", href: "https://x.com/david_heca_" },
  { k: "email", v: email, href: `mailto:${email}` },
];

const cvFiles = [
  { lab: "PDF · ES", href: "/assets/documents/davidherrera-spanish.pdf" },
  { lab: "PDF · EN", href: "/assets/documents/davidherrera-english.pdf" },
];
---

<PageHeader
  idx="04"
  kicker={t("nav.contact")}
  title={t("contact.headerTitle")}
  italic={t("contact.headerItalic")}
  sub={t("contact.description")}
/>

<section class="contact container-editorial">
  <div class="contact__split">
    <!-- left: invitation + CTA + meta -->
    <div class="contact__intro reveal">
      <div class="contact__invite hand lg">
        <Icon name="ph:paper-plane-tilt-duotone" />
        <span set:html={t("contact.invite")}></span>
      </div>

      <div class="contact__cta">
        <a href={`mailto:${email}`} class="contact__cta-btn press-effect">
          <span class="dot"></span>
          {t("contact.cta.button")}
          <span aria-hidden="true">→</span>
        </a>
        <div class="contact__cta-note">{t("contact.cta.note")}</div>
      </div>

      <div class="contact__intro-meta meta-row">
        <span class="icon-row"><Icon name="ph:map-pin-duotone" />{t("hero.metaBar.city")}</span>
        <span class="sep">/</span>
        <span class="icon-row"><Icon name="ph:clock-duotone" />GMT-6</span>
        <span class="sep">/</span>
        <span class="icon-row" style="color: var(--color-accent);">
          <span class="pulse"></span>
          {t("hero.metaBar.status")}
        </span>
      </div>
    </div>

    <!-- right: channels stack -->
    <div class="contact__channels">
      <div class="box accent contact__direct reveal">
        <div class="label accent">{t("contact.directLabel")}</div>
        <div class="contact__direct-email">
          <a href={`mailto:${email}`}>hello@<br />davidherrera.dev</a>
        </div>
        <div class="meta-row" style="margin-top: 12px;">
          <a href={`mailto:${email}`}>copy</a>
          <span class="sep">/</span>
          <a href={`mailto:${email}`}>compose</a>
        </div>
      </div>

      <div class="box solid contact__elsewhere reveal reveal-delay-1">
        <div class="label accent">{t("contact.elsewhereLabel")}</div>
        <div class="contact__elsewhere-grid">
          {elsewhere.map((e) => (
            <a
              href={e.href}
              target={e.href.startsWith("mailto:") ? undefined : "_blank"}
              rel={e.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
              class="contact__elsewhere-item"
            >
              <span class="label">/ {e.k}</span>
              <span class="hand sm">{e.v} ↗</span>
            </a>
          ))}
        </div>
      </div>

      <div class="box solid contact__cv reveal reveal-delay-2">
        <div class="contact__cv-head">
          <div class="label accent">{t("contact.cvLabel")}</div>
          <span class="hand dim sm">{t("contact.cvUpdated")}</span>
        </div>
        <div class="contact__cv-grid">
          {cvFiles.map((f) => (
            <a
              href={f.href}
              target="_blank"
              rel="noopener noreferrer"
              class="box contact__cv-item"
            >
              <div class="contact__cv-label">↓ {f.lab}</div>
            </a>
          ))}
        </div>
      </div>

      <div class="box contact__avail reveal reveal-delay-3">
        <div>
          <div class="label">{t("contact.availLabel")}</div>
          <div class="hand sm" style="margin-top: 4px;">{t("contact.availText")}</div>
        </div>
        <span class="chip accent">
          <span class="dot"></span>
          {t("contact.open")}
        </span>
      </div>
    </div>
  </div>
</section>

<PageFooter lang={lang} num="04" />

<style>
  .contact { padding-bottom: 24px; }
  .contact__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    padding-top: 10px;
  }
  @media (min-width: 1024px) {
    .contact__split { grid-template-columns: 1.1fr 1fr; gap: 40px; }
  }
  .contact__intro {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-top: 8px;
  }
  .contact__invite {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-hand);
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: 1.15;
    color: var(--color-ink);
    flex-wrap: wrap;
  }
  .contact__invite [data-icon] {
    font-size: clamp(28px, 4.5vw, 44px);
    color: var(--color-accent);
  }
  .contact__invite em {
    color: var(--color-accent);
    font-style: italic;
  }
  .contact__intro-meta {
    margin-top: 4px;
  }
  .contact__cta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }
  .contact__cta-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  .contact__channels {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact__direct { padding: 18px 22px; }
  .contact__direct-email {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(28px, 4.5vw, 36px);
    margin-top: 8px;
    color: var(--color-accent);
    line-height: 1.05;
    word-break: break-all;
  }
  .contact__direct-email a { color: inherit; }
  .contact__elsewhere { padding: 16px 20px; }
  .contact__elsewhere-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 12px;
  }
  @media (max-width: 480px) {
    .contact__elsewhere-grid { grid-template-columns: 1fr; }
  }
  .contact__elsewhere-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: var(--line) dashed var(--color-ink-3);
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
    gap: 8px;
  }
  .contact__elsewhere-item:hover { color: var(--color-accent); }
  .contact__elsewhere-item .hand {
    color: var(--color-ink);
    transition: color 0.15s ease;
  }
  .contact__elsewhere-item:hover .hand { color: var(--color-accent); }

  .contact__cv { padding: 16px 20px; }
  .contact__cv-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 10px;
    gap: 10px;
  }
  .contact__cv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  @media (max-width: 480px) {
    .contact__cv-grid { grid-template-columns: 1fr; }
  }
  .contact__cv-item {
    padding: 12px 14px;
    text-align: center;
    border-style: dashed;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
    transition: border-color 0.15s ease;
  }
  .contact__cv-item:hover { border-color: var(--color-accent); }
  .contact__cv-label {
    font-family: var(--font-hand);
    color: var(--color-accent);
    font-size: 19px;
  }

  .contact__avail {
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
