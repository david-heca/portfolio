---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const email = "hello@davidherrera.dev";

const channels = [
  { label: "Email", value: email, href: `mailto:${email}`, icon: "ph:envelope-simple-duotone" },
  { label: "GitHub", value: "@david-heca", href: "https://github.com/david-heca", icon: "ph:github-logo-duotone" },
  { label: "LinkedIn", value: "in/david-heca", href: "https://www.linkedin.com/in/david-heca/", icon: "ph:linkedin-logo-duotone" },
  { label: "X", value: "@david_heca_", href: "https://x.com/david_heca_", icon: "ph:x-logo-duotone" },
];

const cvFiles = [
  { lab: "CV · ES", href: "/assets/documents/davidherrera-spanish.pdf" },
  { lab: "CV · EN", href: "/assets/documents/davidherrera-english.pdf" },
];
---

<section id="contact" class="contact section container">
  <div class="contact__intro reveal">
    <p class="kicker">{t("nav.contact")}</p>
    <h2 class="contact__title">{t("contact.headerTitle")} <em>{t("contact.headerItalic")}</em></h2>
    <p class="lead contact__lead">{t("contact.description")}</p>

    <div class="contact__cta">
      <a href={`mailto:${email}`} class="btn btn--primary">
        <Icon name="ph:paper-plane-tilt-duotone" />
        {t("contact.cta.button")}
      </a>
    </div>
    <p class="contact__note">{t("contact.cta.note")}</p>
  </div>

  <div class="contact__channels reveal reveal-1">
    {channels.map((c) => (
      <a
        href={c.href}
        target={c.href.startsWith("mailto:") ? undefined : "_blank"}
        rel={c.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
        class="channel"
      >
        <span class="channel__icon"><Icon name={c.icon} /></span>
        <span class="channel__text">
          <span class="channel__label">{c.label}</span>
          <span class="channel__value">{c.value}</span>
        </span>
        <span class="channel__arrow" aria-hidden="true">↗</span>
      </a>
    ))}
    <div class="contact__cv">
      {cvFiles.map((f) => (
        <a href={f.href} target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--sm">
          <Icon name="ph:file-pdf-duotone" />
          {f.lab}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (min-width: 900px) { .contact { grid-template-columns: 1.1fr 0.9fr; gap: 64px; } }

  .contact__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.98;
    font-size: clamp(48px, 8vw, 96px);
    color: var(--color-ink);
    margin: 14px 0 0;
  }
  .contact__title em { color: var(--color-accent); font-style: italic; }
  .contact__lead { margin-top: 22px; }

  .contact__cta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px 20px;
    margin-top: 32px;
  }
  .contact__note {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.04em;
    color: var(--color-ink-2);
    margin: 16px 0 0;
  }

  .contact__channels { display: flex; flex-direction: column; }
  .channel {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 4px;
    border-bottom: 1px solid var(--color-line);
    transition: padding 0.18s ease, color 0.18s ease;
  }
  .channel:first-child { border-top: 1px solid var(--color-line); }
  .channel:hover { padding-left: 12px; color: var(--color-accent); }
  .channel__icon {
    display: inline-flex;
    color: var(--color-accent);
  }
  .channel__icon [data-icon] { font-size: 22px; }
  .channel__text { display: flex; flex-direction: column; gap: 2px; }
  .channel__label {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  .channel__value { font-size: var(--text-body); color: var(--color-ink); }
  .channel:hover .channel__value { color: var(--color-accent); }
  .channel__arrow { margin-left: auto; color: var(--color-ink-3); }
  .channel:hover .channel__arrow { color: var(--color-accent); }

  .contact__cv { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
</style>
