---
import { useTranslations } from "@i18n/utils";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Channel {
  k: string;
  v: string;
  href: string;
  external?: boolean;
}

const email = "hello@davidherrera.dev";

const channels: Channel[] = [
  { k: t("contact.channels.email"), v: email, href: `mailto:${email}` },
  { k: t("contact.channels.linkedin"), v: "/in/david-heca", href: "https://www.linkedin.com/in/david-heca/", external: true },
  { k: t("contact.channels.github"), v: "@david-heca", href: "https://github.com/david-heca", external: true },
  { k: t("contact.channels.twitter"), v: "@david_heca_", href: "https://x.com/david_heca_", external: true },
  { k: t("contact.channels.cvEs"), v: t("contact.channels.cvEsValue"), href: "/assets/documents/davidherrera-spanish.pdf", external: true },
  { k: t("contact.channels.cvEn"), v: t("contact.channels.cvEnValue"), href: "/assets/documents/davidherrera-english.pdf", external: true },
];

const headingHtml = t("contact.heading");
const footerGiantHtml = t("contact.footerGiant");
const year = new Date().getFullYear();
---

<section class="contact container-editorial">
  <div class="reveal section-label">// 04. {t("nav.contact")}</div>
  <h1 class="reveal reveal-delay-1 contact__h" set:html={headingHtml}></h1>
  <p class="reveal reveal-delay-2 contact__sub">{t("contact.description")}</p>

  <div class="contact__grid">
    {channels.map((c, i) => (
      <a
        href={c.href}
        target={c.external ? "_blank" : undefined}
        rel={c.external ? "noopener noreferrer" : undefined}
        class={`contact__cell reveal reveal-delay-${Math.min(i + 1, 4)}`}
      >
        <div class="contact__cell-k">{c.k}</div>
        <div class="contact__cell-v">{c.v}</div>
        <div class="contact__cell-arrow" aria-hidden="true">↗</div>
      </a>
    ))}
  </div>

  <div class="contact__cta reveal">
    <a href={`mailto:${email}`} class="contact__cta-btn press-effect">
      <span class="dot" aria-hidden="true"></span>
      {t("contact.cta.button")}
      <span aria-hidden="true">→</span>
    </a>
    <div class="contact__cta-note">{t("contact.cta.note")}</div>
  </div>
</section>

<footer class="footer">
  <div class="footer__inner" style="padding-top: 72px; align-items: flex-end;">
    <div class="footer__giant" set:html={footerGiantHtml}></div>
    <div style="text-align: right;">
      © {year} David Herrera<br />
      v.2026 · Astro + Tailwind + React<br />
      04 / 04
    </div>
  </div>
</footer>
