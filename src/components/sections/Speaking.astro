---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const venues = t("speaking.venues") as unknown as string[];
const topics = t("speaking.topics") as unknown as string[];
const alt = lang === "es" ? "David dando una charla" : "David giving a talk";
---

<section id="speaking" class="speaking section container">
  <div class="speaking__photo reveal">
    <span class="speaking__photo-ph" aria-hidden="true"><Icon name="ph:microphone-stage-duotone" /></span>
    <img src="/assets/speaking.webp" alt={alt} loading="lazy" onerror="this.style.display='none'" />
  </div>

  <div class="speaking__content reveal reveal-1">
    <p class="kicker">{t("speaking.label")}</p>
    <h2 class="section-title">{t("speaking.title")} <em>{t("speaking.titleItalic")}</em></h2>
    <p class="lead speaking__lead">{t("speaking.description")}</p>

    <div class="speaking__audience">
      <Icon name="ph:users-three-duotone" />
      {t("speaking.audience")}
    </div>

    <div class="speaking__meta">
      <div>
        <p class="speaking__meta-label">{t("speaking.venuesLabel")}</p>
        <ul class="speaking__venues">
          {venues.map((v) => <li><Icon name="ph:map-pin-duotone" />{v}</li>)}
        </ul>
      </div>
      <div>
        <p class="speaking__meta-label">{t("speaking.topicsLabel")}</p>
        <div class="speaking__topics">{topics.map((tp) => <span class="tag">{tp}</span>)}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .speaking {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 900px) { .speaking { grid-template-columns: 0.85fr 1.15fr; gap: 64px; } }

  .speaking__photo {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 440px;
    justify-self: center;
    border-radius: var(--radius);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    background: var(--color-bg-2);
  }
  .speaking__photo-ph { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .speaking__photo-ph [data-icon] { font-size: 72px; color: var(--color-ink-3); }
  .speaking__photo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .speaking__lead { margin-top: 22px; }

  .speaking__audience {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    margin-top: 26px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    color: var(--color-ink);
  }
  .speaking__audience [data-icon] { font-size: 28px; color: var(--color-accent); }

  .speaking__meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--color-line);
  }
  @media (min-width: 560px) { .speaking__meta { grid-template-columns: 1fr 1fr; } }
  .speaking__meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 14px;
  }
  .speaking__venues { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 11px; }
  .speaking__venues li {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: var(--text-sm);
    color: var(--color-ink);
  }
  .speaking__venues [data-icon] { font-size: 17px; color: var(--color-accent); }
  .speaking__topics { display: flex; flex-wrap: wrap; gap: 8px; }
</style>
