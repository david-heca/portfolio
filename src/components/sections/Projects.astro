---
import { Image } from "astro:assets";
import { useTranslations } from "@i18n/utils";
import PageHeader from "@ui/PageHeader.astro";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Spec {
  label: string;
  value: string;
}

interface Project {
  num: string;
  slug: string;
  title: string;
  desc: string;
  specs: Spec[];
  kind: string;
  year: string;
  status: string;
  tags: string[];
  image?: string;
  href?: string;
}

const featured: Project = {
  num: "01",
  slug: "connie",
  title: t("projects.list.connie.title"),
  desc: t("projects.list.connie.description"),
  specs: t("projects.list.connie.specs") as unknown as Spec[],
  kind: t("projects.list.connie.kind"),
  year: t("projects.list.connie.year"),
  status: t("projects.list.connie.status"),
  tags: ["RAG", "MCP", "Azure", "Python", "SQL", "JWT"],
  image: "/assets/projects/connie.webp",
};

const rest: Project[] = [
  {
    num: "02",
    slug: "handheld",
    title: t("projects.list.handheld.title"),
    desc: t("projects.list.handheld.description"),
    specs: t("projects.list.handheld.specs") as unknown as Spec[],
    kind: t("projects.list.handheld.kind"),
    year: t("projects.list.handheld.year"),
    status: t("projects.list.handheld.status"),
    tags: ["Java", "Android", "Material", "SQL"],
    image: "/assets/projects/handheld.webp",
  },
  {
    num: "03",
    slug: "trace",
    title: t("projects.list.trace.title"),
    desc: t("projects.list.trace.description"),
    specs: t("projects.list.trace.specs") as unknown as Spec[],
    kind: t("projects.list.trace.kind"),
    year: t("projects.list.trace.year"),
    status: t("projects.list.trace.status"),
    tags: ["C#", "DevExpress", "SQL"],
    image: "/assets/projects/trace.webp",
  },
  {
    num: "04",
    slug: "portfolio",
    title: t("projects.list.portfolio.title"),
    desc: t("projects.list.portfolio.description"),
    specs: t("projects.list.portfolio.specs") as unknown as Spec[],
    kind: t("projects.list.portfolio.kind"),
    year: t("projects.list.portfolio.year"),
    status: t("projects.list.portfolio.status"),
    tags: ["Astro", "Tailwind", "React"],
    image: "/assets/projects/portfolio.webp",
    href: "https://github.com/david-heca/portfolio",
  },
];
---

<PageHeader
  idx="02"
  kicker={t("nav.projects")}
  title={t("projects.headerTitle")}
  italic={t("projects.headerItalic")}
  sub={t("projects.description")}
/>

<section class="projects container-editorial">
  <div class="projects__featured reveal">
    <div class="projects__cover">
      <div class="placeholder">
        {featured.image ? (
          <Image
            src={featured.image}
            alt={featured.title}
            width={1280}
            height={800}
            loading="lazy"
            quality={85}
          />
        ) : (
          <span>cover · {featured.title}</span>
        )}
      </div>
      <div class="projects__cover-badge-l">
        <span class="chip accent">
          <span class="dot"></span>
          {t("projects.featuredLabel")}
        </span>
      </div>
      <div class="projects__cover-badge-r">
        <span class="label">/ {featured.num}</span>
      </div>
    </div>

    <div class="projects__feat-content">
      <div>
        <div class="meta-row projects__feat-meta">
          <span style="color: var(--color-accent);">{featured.kind}</span>
          <span class="sep">·</span>
          <span>{featured.year}</span>
          <span class="sep">·</span>
          <span>{featured.status}</span>
        </div>
        <div class="projects__feat-title">
          {featured.title}<span class="accent-dot">.</span>
        </div>
        <div class="projects__feat-desc">{featured.desc}</div>
        <dl class="spec-sheet projects__feat-specs">
          {featured.specs.map((s) => (
            <div class="spec-sheet__row">
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div>
        <div class="projects__feat-tags">
          {featured.tags.map((t) => <span class="chip">{t}</span>)}
        </div>
      </div>
    </div>
  </div>

  <div class="projects__divider reveal">
    <span class="hr"></span>
    <span class="label-mid">{t("projects.moreProjects")}</span>
    <span class="hr"></span>
  </div>

  <div class="projects__grid">
    {rest.map((p, i) => (
      <a
        href={p.href ?? "#"}
        target={p.href ? "_blank" : undefined}
        rel={p.href ? "noopener noreferrer" : undefined}
        class={`box solid project-card reveal reveal-delay-${Math.min(i + 1, 4)}`}
        style={p.href ? "" : "pointer-events: none;"}
      >
        <div class="project-card__cover placeholder">
          {p.image ? (
            <Image
              src={p.image}
              alt={p.title}
              width={800}
              height={600}
              loading="lazy"
              quality={80}
            />
          ) : (
            <span>cover · {p.title}</span>
          )}
        </div>
        <div class="project-card__body">
          <div class="project-card__head">
            <span class="label">{p.kind} · {p.year}</span>
            <span class="project-card__num">{p.num}</span>
          </div>
          <div class="project-card__title">{p.title}</div>
          <div class="project-card__desc">{p.desc}</div>
          <dl class="spec-sheet project-card__specs">
            {p.specs.map((s) => (
              <div class="spec-sheet__row">
                <dt>{s.label}</dt>
                <dd>{s.value}</dd>
              </div>
            ))}
          </dl>
          <div class="project-card__tags">
            {p.tags.map((t) => <span class="chip">{t}</span>)}
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<PageFooter lang={lang} num="02" />

<style>
  .projects { padding-bottom: 80px; }
  .projects__featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin: 10px 0 30px;
  }
  .projects__featured > * { min-width: 0; }
  @media (min-width: 1024px) {
    .projects__featured { grid-template-columns: 1.4fr 1fr; gap: 40px; }
  }
  .projects__cover {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
  }
  @media (min-width: 1024px) {
    .projects__cover {
      aspect-ratio: auto;
      height: 440px;
    }
  }
  .projects__cover .placeholder { position: absolute; inset: 0; }
  .projects__cover-badge-l {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
  }
  .projects__cover-badge-r {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
  }
  .projects__feat-content {
    padding: 8px 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
  }
  .projects__feat-meta { margin-bottom: 14px; }
  .projects__feat-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.9;
    font-size: clamp(56px, 9vw, 80px);
    color: var(--color-ink);
  }
  .projects__feat-title .accent-dot { color: var(--color-accent); font-style: normal; }
  .projects__feat-desc {
    font-size: var(--text-lead);
    line-height: var(--leading-prose);
    margin-top: 18px;
    max-width: 420px;
    color: var(--color-ink);
  }

  /* Ficha técnica — blueprint spec sheet (híbrido) */
  .spec-sheet {
    margin: 0;
    border-top: var(--line) dashed var(--color-ink-3);
  }
  .spec-sheet__row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 14px;
    padding: 7px 0;
    border-bottom: var(--line) dashed var(--color-ink-3);
  }
  .spec-sheet dt {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0;
    padding-top: 2px;
  }
  .spec-sheet dd {
    margin: 0;
    font-size: var(--text-body);
    line-height: 1.45;
    color: var(--color-ink);
  }
  .projects__feat-specs {
    margin-top: 22px;
    max-width: 440px;
  }
  .projects__feat-specs .spec-sheet__row { grid-template-columns: 84px 1fr; padding: 9px 0; }
  .projects__feat-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .projects__feat-tags .chip { padding: 4px 10px; }
  .projects__feat-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .projects__feat-actions .chip { padding: 5px 14px; cursor: pointer; }

  .projects__divider {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 10px 0 24px;
  }
  .projects__divider .hr { flex: 1; }
  .projects__divider .label-mid {
    font-family: var(--font-hand);
    color: var(--color-ink-2);
    font-size: 18px;
    white-space: nowrap;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  .projects__grid > * { min-width: 0; }
  @media (min-width: 768px) {
    .projects__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .projects__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }
  .project-card__cover {
    height: 180px;
    border-radius: 0;
    border: none;
    border-bottom: var(--line) solid var(--color-ink-3);
    position: relative;
  }
  .project-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .project-card__body {
    padding: 14px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .project-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }
  .project-card__num {
    font-family: var(--font-hand);
    font-size: 17px;
    color: var(--color-ink-2);
  }
  .project-card__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 32px;
    line-height: 1;
    color: var(--color-ink);
  }
  .project-card__desc {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-2);
  }
  .project-card__specs { margin-top: 2px; }
  .project-card__specs .spec-sheet__row { grid-template-columns: 62px 1fr; gap: 10px; padding: 6px 0; }
  .project-card__specs dt { font-size: 9px; letter-spacing: 0.12em; }
  .project-card__specs dd { font-size: 11.5px; line-height: 1.4; color: var(--color-ink-2); }
  .project-card__tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .project-card__tags .chip { padding: 2px 7px; font-size: 9px; }
</style>
