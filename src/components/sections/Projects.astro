---
import { Image } from "astro:assets";
import { useTranslations } from "@i18n/utils";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Spec { label: string; value: string }
interface Project {
  slug: string;
  title: string;
  desc: string;
  specs: Spec[];
  kind: string;
  year: string;
  status: string;
  tags: string[];
  image: string;
  href?: string;
}

const build = (slug: string, tags: string[], image: string, href?: string): Project => ({
  slug,
  title: t(`projects.list.${slug}.title`),
  desc: t(`projects.list.${slug}.description`),
  specs: t(`projects.list.${slug}.specs`) as unknown as Spec[],
  kind: t(`projects.list.${slug}.kind`),
  year: t(`projects.list.${slug}.year`),
  status: t(`projects.list.${slug}.status`),
  tags,
  image,
  href,
});

const featured = build("connie", ["RAG", "MCP", "Azure", "Python", "SQL"], "/assets/projects/connie.webp");
const rest = [
  build("handheld", ["Java", "Android", "SQL"], "/assets/projects/handheld.webp"),
  build("trace", ["C#", "DevExpress", "SQL"], "/assets/projects/trace.webp"),
  build("portfolio", ["Astro", "Tailwind", "TS"], "/assets/projects/portfolio.webp", "https://github.com/david-heca/portfolio"),
];
---

<section id="projects" class="projects section container">
  <header class="sec-head reveal">
    <p class="kicker">{t("nav.projects")}</p>
    <h2 class="section-title">{t("projects.headerTitle")} <em>{t("projects.headerItalic")}</em></h2>
    <p class="lead">{t("projects.description")}</p>
  </header>

  <article class="featured card reveal">
    <div class="featured__cover">
      <Image src={featured.image} alt={featured.title} width={1100} height={720} loading="lazy" quality={85} />
      <span class="featured__badge">{t("projects.featuredLabel")}</span>
    </div>
    <div class="featured__body">
      <p class="proj__meta">{featured.kind} · {featured.year} · {featured.status}</p>
      <h3 class="featured__title">{featured.title}</h3>
      <p class="featured__desc">{featured.desc}</p>
      <dl class="specs">
        {featured.specs.map((s) => (
          <div class="specs__row">
            <dt>{s.label}</dt>
            <dd>{s.value}</dd>
          </div>
        ))}
      </dl>
      <div class="proj__tags">
        {featured.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </article>

  <div class="projects__grid">
    {rest.map((p, i) => {
      const Tag = p.href ? "a" : "div";
      return (
        <Tag
          href={p.href}
          target={p.href ? "_blank" : undefined}
          rel={p.href ? "noopener noreferrer" : undefined}
          class={`card proj reveal reveal-${Math.min(i + 1, 3)}`}
        >
          <div class="proj__cover">
            <Image src={p.image} alt={p.title} width={720} height={480} loading="lazy" quality={80} />
          </div>
          <div class="proj__body">
            <p class="proj__meta">{p.kind} · {p.year}</p>
            <h3 class="proj__title">{p.title}</h3>
            <p class="proj__desc">{p.desc}</p>
            <dl class="specs">
              {p.specs.map((s) => (
                <div class="specs__row">
                  <dt>{s.label}</dt>
                  <dd>{s.value}</dd>
                </div>
              ))}
            </dl>
            <div class="proj__tags">
              {p.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </Tag>
      );
    })}
  </div>
</section>

<style>
  .sec-head { max-width: 720px; margin-bottom: 56px; }
  .sec-head .lead { margin-top: 20px; }

  .proj__meta {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0;
  }
  .proj__tags { display: flex; flex-wrap: wrap; gap: 7px; }

  /* featured */
  .featured {
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    margin-bottom: 24px;
  }
  @media (min-width: 900px) {
    .featured { grid-template-columns: 1.2fr 1fr; align-items: stretch; }
  }
  .featured__cover { position: relative; min-height: 280px; background: var(--color-bg-2); }
  .featured__cover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .featured__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.06em;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .featured__body {
    padding: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .featured__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1;
    color: var(--color-ink);
    margin: 4px 0 0;
  }
  .featured__desc {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0;
  }

  /* grid cards */
  .projects__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) { .projects__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .projects__grid { grid-template-columns: repeat(3, 1fr); } }

  .proj { display: flex; flex-direction: column; overflow: hidden; }
  .proj__cover { height: 200px; flex-shrink: 0; background: var(--color-bg-2); }
  .proj__cover img { width: 100%; height: 100%; object-fit: cover; }
  .proj__body {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .proj__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    line-height: 1;
    color: var(--color-ink);
    margin: 2px 0 0;
  }
  .proj__desc {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0;
  }

  /* specs */
  .specs { margin: 4px 0 0; display: flex; flex-direction: column; gap: 8px; }
  .specs__row { display: grid; grid-template-columns: 64px 1fr; gap: 14px; align-items: baseline; }
  .specs dt {
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0;
  }
  .specs dd {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-ink-2);
  }
  .featured .specs__row { grid-template-columns: 80px 1fr; }
</style>
