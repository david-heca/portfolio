---
import { Image } from "astro:assets";
import { useTranslations } from "@i18n/utils";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Project {
  num: string;
  slug: string;
  title: string;
  desc: string;
  kind: string;
  year: string;
  status: string;
  tags: string[];
  image?: string;
  featured?: boolean;
  accent?: boolean;
  href?: string;
}

const featured: Project = {
  num: "01",
  slug: "connie",
  title: t("projects.list.connie.title"),
  desc: t("projects.list.connie.description"),
  kind: t("projects.list.connie.kind"),
  year: t("projects.list.connie.year"),
  status: t("projects.list.connie.status"),
  tags: ["React", "RAG", "SQL", "JWT", "Python", "Azure"],
  image: "/assets/projects/connie.webp",
  featured: true,
  accent: true,
};

const rest: Project[] = [
  {
    num: "02",
    slug: "handheld",
    title: t("projects.list.handheld.title"),
    desc: t("projects.list.handheld.description"),
    kind: t("projects.list.handheld.kind"),
    year: t("projects.list.handheld.year"),
    status: t("projects.list.handheld.status"),
    tags: ["Java", "Android", "Material", "SQL"],
    image: "/assets/projects/handheld.webp",
  },
  {
    num: "03",
    slug: "trace",
    title: t("projects.list.trace.title"),
    desc: t("projects.list.trace.description"),
    kind: t("projects.list.trace.kind"),
    year: t("projects.list.trace.year"),
    status: t("projects.list.trace.status"),
    tags: ["C#", "DevExpress", "SQL"],
    image: "/assets/projects/trace.webp",
  },
  {
    num: "04",
    slug: "portfolio",
    title: t("projects.list.portfolio.title"),
    desc: t("projects.list.portfolio.description"),
    kind: t("projects.list.portfolio.kind"),
    year: t("projects.list.portfolio.year"),
    status: t("projects.list.portfolio.status"),
    tags: ["Astro", "Tailwind", "React", "Markdown"],
    image: "/assets/projects/portfolio.webp",
    href: "https://github.com/david-heca/portfolio",
    accent: true,
  },
];

const headingHtml = t("projects.heading");
---

<section class="projects container-editorial">
  <div class="reveal section-label">// 02. {t("nav.projects")}</div>
  <h1 class="reveal reveal-delay-1 projects__h" set:html={headingHtml}></h1>
  <p class="reveal reveal-delay-2 work__sub" style="margin-bottom: 0;">{t("projects.description")}</p>

  <div class="project project--feat reveal">
    <div class={`project__cover ${featured.accent ? "project__cover--accent" : ""}`}>
      <div class="project__num">{featured.num}</div>
      <div class="project__kind">{t("projects.featuredLabel")}</div>
      {featured.image ? (
        <Image
          src={featured.image}
          alt={featured.title}
          width={1280}
          height={800}
          loading="lazy"
          quality={85}
        />
      ) : (
        <div class="project__cover-placeholder">[ cover · {featured.title} ]</div>
      )}
    </div>
    <div>
      <div class="project__meta">
        <span>{featured.kind}</span>
        <span>{featured.year} · {featured.status}</span>
      </div>
      <div class="project__title">{featured.title}</div>
      <div class="project__desc">{featured.desc}</div>
      <div class="project__tags">
        {featured.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </div>

  <div class="projects__more-label reveal">{t("projects.moreProjects")}</div>

  <div class="projects__grid">
    {rest.map((p, i) => (
      <div class={`project reveal reveal-delay-${Math.min(i + 1, 4)}`}>
        <div class={`project__cover ${p.accent ? "project__cover--accent" : ""}`}>
          <div class="project__num">{p.num}</div>
          {p.image ? (
            <Image
              src={p.image}
              alt={p.title}
              width={800}
              height={600}
              loading="lazy"
              quality={80}
            />
          ) : (
            <div class="project__cover-placeholder">[ cover · {p.title} ]</div>
          )}
        </div>
        <div class="project__meta">
          <span>{p.kind}</span>
          <span>{p.year} · {p.status}</span>
        </div>
        <div class="project__title" style="font-size: clamp(22px, 3.5vw, 32px);">{p.title}</div>
        <div class="project__desc">{p.desc}</div>
        <div class="project__tags">
          {p.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<PageFooter lang={lang} num="02" />
