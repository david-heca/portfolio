---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const principles = t("about.principles") as unknown as { title: string; body: string }[];
const principleIcons = [
  "ph:rocket-launch-duotone",
  "ph:gauge-duotone",
  "ph:chalkboard-teacher-duotone",
];
---

<section id="about" class="about section container">
  <div class="about__top">
    <header class="about__head">
      <p class="kicker reveal">{t("about.label")}</p>
      <h2 class="section-title reveal reveal-1" set:html={t("about.heading")}></h2>
    </header>

    <div class="about__body">
      <p class="prose reveal" set:html={t("about.bio.paragraph1")}></p>
      <p class="prose reveal reveal-1" set:html={t("about.bio.paragraph2")}></p>
      <p class="prose reveal reveal-2" set:html={t("about.bio.paragraph3")}></p>
    </div>
  </div>

  <div class="about__principles">
    {principles.map((p, i) => (
      <div class={`about__principle reveal reveal-${Math.min(i + 1, 3)}`}>
        <span class="about__principle-icon"><Icon name={principleIcons[i] ?? "ph:circle-duotone"} /></span>
        <h3 class="about__principle-title">{p.title}</h3>
        <p class="about__principle-body">{p.body}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .about__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px 64px;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .about__top { grid-template-columns: 0.85fr 1.15fr; }
    .about__head { position: sticky; top: 110px; }
  }

  .about__body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about__principles {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 24px;
    padding-top: 40px;
    border-top: 1px solid var(--color-line);
  }
  @media (min-width: 768px) {
    .about__principles { grid-template-columns: repeat(3, 1fr); gap: 32px; }
  }
  .about__principle-icon { display: block; margin-bottom: 14px; }
  .about__principle-icon [data-icon] { font-size: 32px; color: var(--color-accent); }
  .about__principle-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 10px;
  }
  .about__principle-body {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-2);
    margin: 0;
  }
</style>
