---
import { useTranslations } from "@i18n/utils";
import PageFooter from "@ui/PageFooter.astro";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Role {
  title: string;
  period: string;
  stack: string[];
  bullets: string[];
  accent?: boolean;
}

interface Company {
  idx: string;
  name: string;
  meta: string[];
  roles: Role[];
}

const companies: Company[] = [
  {
    idx: "01",
    name: t("work.companies.baacc.name"),
    meta: [
      t("work.companies.baacc.totalPeriod"),
      t("work.companies.baacc.location"),
      t("work.companies.baacc.workMode"),
    ],
    roles: [
      {
        title: t("work.companies.baacc.roles.architect.title"),
        period: `${t("work.companies.baacc.roles.architect.period")} · ${t("work.companies.baacc.roles.architect.type")}`,
        stack: ["LLM", "MCP", "RAG", "MLOps", "APIs"],
        bullets: [
          t("work.companies.baacc.roles.architect.achievements.0"),
          t("work.companies.baacc.roles.architect.achievements.1"),
          t("work.companies.baacc.roles.architect.achievements.2"),
          t("work.companies.baacc.roles.architect.achievements.3"),
        ],
        accent: true,
      },
      {
        title: t("work.companies.baacc.roles.fullstack.title"),
        period: `${t("work.companies.baacc.roles.fullstack.period")} · ${t("work.companies.baacc.roles.fullstack.type")}`,
        stack: [".NET", "Python", "SQL", "Android"],
        bullets: [
          t("work.companies.baacc.roles.fullstack.achievements.0"),
          t("work.companies.baacc.roles.fullstack.achievements.1"),
          t("work.companies.baacc.roles.fullstack.achievements.2"),
          t("work.companies.baacc.roles.fullstack.achievements.3"),
        ],
      },
      {
        title: t("work.companies.baacc.roles.junior.title"),
        period: `${t("work.companies.baacc.roles.junior.period")} · ${t("work.companies.baacc.roles.junior.type")}`,
        stack: ["MVC", "SQL", "APIs"],
        bullets: [
          t("work.companies.baacc.roles.junior.achievements.0"),
          t("work.companies.baacc.roles.junior.achievements.1"),
        ],
      },
    ],
  },
  {
    idx: "02",
    name: t("work.companies.dec.name"),
    meta: [
      t("work.companies.dec.totalPeriod"),
      t("work.companies.dec.location"),
      t("work.companies.dec.workMode"),
    ],
    roles: [
      {
        title: t("work.companies.dec.roles.webdev.title"),
        period: `${t("work.companies.dec.roles.webdev.period")} · ${t("work.companies.dec.roles.webdev.type")}`,
        stack: ["HTML", "CSS", "JS", "WordPress"],
        bullets: [
          t("work.companies.dec.roles.webdev.achievements.0"),
          t("work.companies.dec.roles.webdev.achievements.1"),
          t("work.companies.dec.roles.webdev.achievements.2"),
        ],
      },
    ],
  },
];

const headingHtml = t("work.heading");
---

<section class="work container-editorial">
  <div class="reveal section-label">// 01. {t("nav.work")}</div>
  <h1 class="reveal reveal-delay-1 work__h" set:html={headingHtml}></h1>
  <p class="reveal reveal-delay-2 work__sub">{t("work.description")}</p>

  {companies.map((co, i) => (
    <div class={`job reveal ${i > 0 ? `reveal-delay-${Math.min(i, 4)}` : ""}`}>
      <div class="job__idx">/ {co.idx}</div>
      <div class="job__co-wrap">
        <div class="job__co">{co.name}</div>
        <div class="job__co-meta">
          {co.meta.map((m) => <div>{m}</div>)}
        </div>
      </div>
      <div class="job__roles">
        {co.roles.map((role) => (
          <div class="role">
            <div class="role__head">
              <div class="role__title">{role.title}</div>
              <div class="role__period">{role.period}</div>
            </div>
            <div class="role__stack">
              {role.stack.map((s) => (
                <span class={`tag ${role.accent ? "accent" : ""}`}>{s}</span>
              ))}
            </div>
            <ul class="role__body">
              {role.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  ))}
</section>

<PageFooter lang={lang} num="01" />
