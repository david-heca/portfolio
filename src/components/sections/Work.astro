---
import { useTranslations } from "@i18n/utils";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Role {
  title: string;
  period: string;
  type: string;
  achievements: string[];
  stack: string[];
  current?: boolean;
}
interface Company {
  name: string;
  span: string;
  loc: string;
  mode: string;
  roles: Role[];
}

const companies: Company[] = [
  {
    name: t("work.companies.baacc.name").replace(/ S\.A\. de C\.V\./, ""),
    span: t("work.companies.baacc.totalPeriod"),
    loc: t("work.companies.baacc.location"),
    mode: t("work.companies.baacc.workMode"),
    roles: [
      {
        title: t("work.companies.baacc.roles.architect.title"),
        period: t("work.companies.baacc.roles.architect.period"),
        type: t("work.companies.baacc.roles.architect.type"),
        achievements: t("work.companies.baacc.roles.architect.achievements") as unknown as string[],
        stack: ["LLMs", "RAG", "MCP", "MLOps", "Azure"],
        current: true,
      },
      {
        title: t("work.companies.baacc.roles.fullstack.title"),
        period: t("work.companies.baacc.roles.fullstack.period"),
        type: t("work.companies.baacc.roles.fullstack.type"),
        achievements: t("work.companies.baacc.roles.fullstack.achievements") as unknown as string[],
        stack: [".NET", "Python", "SQL", "Android"],
      },
      {
        title: t("work.companies.baacc.roles.junior.title"),
        period: t("work.companies.baacc.roles.junior.period"),
        type: t("work.companies.baacc.roles.junior.type"),
        achievements: t("work.companies.baacc.roles.junior.achievements") as unknown as string[],
        stack: ["MVC", "SQL", "APIs"],
      },
    ],
  },
  {
    name: t("work.companies.dec.name"),
    span: t("work.companies.dec.totalPeriod"),
    loc: t("work.companies.dec.location"),
    mode: t("work.companies.dec.workMode"),
    roles: [
      {
        title: t("work.companies.dec.roles.webdev.title"),
        period: t("work.companies.dec.roles.webdev.period"),
        type: t("work.companies.dec.roles.webdev.type"),
        achievements: t("work.companies.dec.roles.webdev.achievements") as unknown as string[],
        stack: ["HTML", "CSS", "JavaScript", "WordPress"],
      },
    ],
  },
];
---

<section id="work" class="work section container">
  <header class="sec-head reveal">
    <p class="kicker">{t("nav.work")}</p>
    <h2 class="section-title">{t("work.headerTitle")} <em>{t("work.headerItalic")}</em></h2>
    <p class="lead work__lead">{t("work.description")}</p>
  </header>

  <div class="work__list">
    {companies.map((co) => (
      <article class="work__company reveal">
        <div class="work__company-head">
          <h3 class="work__company-name">{co.name}</h3>
          <span class="work__company-meta">{co.span} · {co.loc} · {co.mode}</span>
        </div>

        <div class="work__roles">
          {co.roles.map((r) => (
            <div class="role">
              <div class="role__aside">
                <span class="role__period">{r.period}</span>
                {r.current && (
                  <span class="role__now"><span class="dot"></span>{t("work.current")}</span>
                )}
              </div>
              <div class="role__main">
                <h4 class="role__title">{r.title}</h4>
                <span class="role__type">{r.type}</span>
                <ul class="role__achievements">
                  {r.achievements.map((a) => <li>{a}</li>)}
                </ul>
                <div class="role__stack">
                  {r.stack.map((s) => <span class="tag">{s}</span>)}
                </div>
              </div>
            </div>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .sec-head { max-width: 720px; margin-bottom: 56px; }
  .work__lead { margin-top: 20px; }

  .work__list { display: flex; flex-direction: column; gap: 56px; }

  .work__company-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px 20px;
    padding-bottom: 18px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--color-line);
  }
  .work__company-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1;
    color: var(--color-ink);
    margin: 0;
  }
  .work__company-meta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.03em;
    color: var(--color-ink-2);
  }

  .work__roles { display: flex; flex-direction: column; gap: 36px; }

  .role {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 768px) {
    .role { grid-template-columns: 170px 1fr; gap: 32px; }
  }
  .role__aside { display: flex; flex-direction: column; gap: 10px; }
  .role__period {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.04em;
    color: var(--color-ink-2);
  }
  .role__now {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .role__title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-card-title);
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }
  .role__type {
    display: inline-block;
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-label-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  .role__achievements {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: var(--measure);
  }
  .role__achievements li {
    position: relative;
    padding-left: 22px;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-ink-2);
  }
  .role__achievements li::before {
    content: "";
    position: absolute;
    left: 2px;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }
  .role__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 18px;
  }
</style>
