---
import { getLangFromUrl } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

function getPathForLang(l: string) {
  let path = currentPath;
  const parts = path.split("/");
  if (parts[1] === "en" || parts[1] === "es") {
    parts.splice(1, 1);
    path = parts.join("/") || "/";
  }
  if (l === "es") return path;
  return `/${l}${path === "/" ? "" : path}`;
}

const esHref = getPathForLang("es");
const enHref = getPathForLang("en");
---

<div class="seg lang-picker" role="group" aria-label="Language">
  <a
    href={esHref}
    data-target-lang="es"
    class={lang === "es" ? "active" : ""}
    aria-current={lang === "es" ? "true" : undefined}
    title="Español"
  >ES</a>
  <a
    href={enHref}
    data-target-lang="en"
    class={lang === "en" ? "active" : ""}
    aria-current={lang === "en" ? "true" : undefined}
    title="English"
  >EN</a>
</div>

<script>
  function setupLangPicker() {
    document.querySelectorAll<HTMLAnchorElement>(".lang-picker [data-target-lang]").forEach((el) => {
      if (el.dataset.langReady) return;
      el.addEventListener("click", () => {
        const t = el.dataset.targetLang;
        if (t) localStorage.setItem("preferred-lang", t);
      });
      el.dataset.langReady = "true";
    });
  }
  setupLangPicker();
  document.addEventListener("astro:page-load", setupLangPicker);
</script>
