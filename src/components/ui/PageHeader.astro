---
interface Props {
  idx: string;
  kicker: string;
  title: string;
  italic: string;
  sub: string;
}

const { idx, kicker, title, italic, sub } = Astro.props;
---

<div class="page-header container-editorial">
  <div>
    <div class="reveal page-header__kicker label accent">// {idx}. {kicker}</div>
    <h1 class="reveal reveal-delay-1 page-header__title">
      {title}{" "}<span class="accent">{italic}</span><span class="dot">.</span>
    </h1>
  </div>
  <div class="reveal reveal-delay-2 page-header__sub">
    {sub}
  </div>
</div>

<style>
  .page-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: end;
    padding-top: 32px;
    padding-bottom: 24px;
  }
  @media (min-width: 1024px) {
    .page-header {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
      padding-bottom: 28px;
    }
  }
  .page-header__kicker { margin-bottom: 16px; }
  .page-header__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.86;
    color: var(--color-ink);
    margin: 0;
    font-size: clamp(56px, 11vw, 132px);
  }
  .page-header__title .accent { color: var(--color-accent); }
  .page-header__title .dot {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: clamp(28px, 5vw, 60px);
    color: var(--color-ink-2);
    margin-left: 6px;
  }
  .page-header__sub {
    font-size: 14px;
    line-height: 1.6;
    max-width: 460px;
    color: var(--color-ink);
    padding-bottom: 8px;
  }
  @media (min-width: 1024px) {
    .page-header__sub { padding-bottom: 18px; }
  }
</style>
