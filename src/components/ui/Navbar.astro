---
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import ThemeToggle from "@ui/ThemeToggle.astro";
import LanguagePicker from "@ui/LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { id: "home",      href: lang === "es" ? "/" : "/en",            idx: "00", label: t("nav.home") },
  { id: "work",      href: lang === "es" ? "/work" : "/en/work",   idx: "01", label: t("nav.work") },
  { id: "projects",  href: lang === "es" ? "/projects" : "/en/projects", idx: "02", label: t("nav.projects") },
  { id: "education", href: lang === "es" ? "/education" : "/en/education", idx: "03", label: t("nav.education") },
  { id: "contact",   href: lang === "es" ? "/contact" : "/en/contact", idx: "04", label: t("nav.contact") },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string): boolean {
  if (href === "/" || href === "/en") return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="nav">
  <div class="nav__inner">
    <a href={lang === "es" ? "/" : "/en"} class="nav__brand" aria-label="David Herrera - Home">
      <span class="nav__brand-dot" aria-hidden="true"></span>
      <span>davidherrera.dev</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-astro-prefetch="hover"
          class={`nav__link ${isActive(item.href) ? "active" : ""}`}
        >
          <span class="idx">{item.idx}</span>{item.label}
          <span class="underline" aria-hidden="true"></span>
        </a>
      ))}
    </nav>

    <div class="nav__utils">
      <LanguagePicker />
      <div class="nav__utils-desktop">
        <span aria-hidden="true" style="width:1px;height:14px;background:var(--color-line);"></span>
        <ThemeToggle />
      </div>
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-astro-prefetch
          class={`mobile-menu__link ${isActive(item.href) ? "active" : ""}`}
        >
          <span class="idx">{item.idx}</span>{item.label}
          {isActive(item.href) && <span class="dot" aria-hidden="true"></span>}
        </a>
      ))}
    </nav>
    <div class="mobile-menu__footer">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .nav__utils-desktop {
    display: none;
    align-items: center;
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .nav__utils-desktop {
      display: inline-flex;
    }
  }

  .mobile-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    background: transparent;
    border: 0;
    color: var(--color-ink-2);
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
  }

  @media (min-width: 1024px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 16px 20px;
    border-top: 1px solid var(--color-line);
  }

  @media (min-width: 1024px) {
    .mobile-menu__footer {
      display: none;
    }
  }

  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-line);
    transform: translateY(-8px) scaleY(0.98);
    opacity: 0;
    pointer-events: none;
    transform-origin: top;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .mobile-menu.open {
    transform: translateY(0) scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink-2);
    text-decoration: none;
    border-top: 1px solid var(--color-line);
    transition: background-color 0.15s ease;
  }

  .mobile-menu__link:first-child { border-top: 0; }

  .mobile-menu__link:hover,
  .mobile-menu__link:active {
    background: var(--color-bg-2);
  }

  .mobile-menu__link.active {
    color: var(--color-ink);
  }

  .mobile-menu__link .idx {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-ink-3);
  }

  .mobile-menu__link .dot {
    margin-left: auto;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }
</style>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu || (btn as HTMLElement).dataset.ready) return;

    const links = menu.querySelectorAll("a");
    let isOpen = false;

    function setOpen(open: boolean) {
      isOpen = open;
      menu!.classList.toggle("open", open);
      btn!.setAttribute("aria-expanded", open ? "true" : "false");
      menu!.setAttribute("aria-hidden", open ? "false" : "true");
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!isOpen);
    });

    links.forEach((l) => l.addEventListener("click", () => setOpen(false)));

    document.addEventListener("click", (e) => {
      if (isOpen && !menu!.contains(e.target as Node) && e.target !== btn) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) setOpen(false);
    });

    document.addEventListener("astro:before-preparation", () => setOpen(false));

    (btn as HTMLElement).dataset.ready = "true";
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
