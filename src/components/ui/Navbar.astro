---
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import ThemeToggle from "@ui/ThemeToggle.astro";
import LanguagePicker from "@ui/LanguagePicker.astro";
import { sections } from "@/config";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = lang === "es" ? "/" : "/en";

const navItems = [
  { id: "about", label: t("nav.about"), icon: "ph:user" },
  { id: "work", label: t("nav.work"), icon: "ph:briefcase" },
  { id: "projects", label: t("nav.projects"), icon: "ph:squares-four" },
  { id: "education", label: t("nav.education"), icon: "ph:graduation-cap" },
  ...(sections.speaking
    ? [{ id: "speaking", label: t("nav.speaking"), icon: "ph:microphone-stage" }]
    : []),
  { id: "contact", label: t("nav.contact"), icon: "ph:paper-plane-tilt" },
];
---

<header class="nav">
  <div class="nav__inner">
    <a href={`${home}#top`} class="nav__brand" aria-label="David Herrera">
      david<span>herrera</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {navItems.map((item) => (
        <a href={`#${item.id}`} class="nav__link" data-spy={item.id}>
          <Icon name={item.icon} aria-hidden="true" />
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav__utils">
      <div class="nav__utils-desktop">
        <LanguagePicker />
        <ThemeToggle />
      </div>
      <button id="menu-btn" class="menu-btn" aria-label="Menu" aria-expanded="false">
        <Icon name="ph:list-bold" style="font-size: 22px;" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile">
      {navItems.map((item) => (
        <a href={`#${item.id}`} class="mobile-menu__link" data-spy={item.id}>
          <Icon name={item.icon} aria-hidden="true" />
          {item.label}
        </a>
      ))}
    </nav>
    <div class="mobile-menu__footer">
      <LanguagePicker expanded />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 14px 16px;
  }

  .nav__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 8px 8px 22px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-bg) 70%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
  }

  .nav__brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--color-ink);
    flex-shrink: 0;
  }
  .nav__brand span { color: var(--color-accent); }

  .nav__links {
    display: none;
    gap: 4px;
    align-items: center;
  }
  @media (min-width: 1024px) { .nav__links { display: inline-flex; } }
  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13.5px;
    line-height: 1;
    font-weight: 500;
    color: var(--color-ink-2);
    padding: 8px 13px;
    border-radius: 999px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav__link:hover { color: var(--color-ink); background: var(--color-bg-2); }
  .nav__link.active { color: var(--color-accent); background: var(--color-accent-soft); }
  .nav__link [data-icon] {
    width: 15px;
    height: 15px;
    font-size: 15px;
    color: var(--color-ink-3);
    transition: color 0.15s ease;
  }
  .nav__link:hover [data-icon] { color: var(--color-ink-2); }
  .nav__link.active [data-icon] { color: var(--color-accent); }

  .nav__utils { display: inline-flex; align-items: center; gap: 10px; }
  .nav__utils-desktop { display: none; align-items: center; gap: 4px; }
  @media (min-width: 1024px) { .nav__utils-desktop { display: inline-flex; } }

  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: var(--color-ink-2);
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 999px;
  }
  .menu-btn:hover { background: var(--color-bg-2); color: var(--color-ink); }
  @media (min-width: 1024px) { .menu-btn { display: none; } }

  .mobile-menu {
    position: absolute;
    top: calc(100% - 2px);
    left: 16px;
    right: 16px;
    max-width: 1000px;
    margin: 0 auto;
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .mobile-menu.open { transform: none; opacity: 1; pointer-events: auto; }
  .mobile-menu nav { display: flex; flex-direction: column; padding: 8px; }
  .mobile-menu__link {
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 13px 16px;
    font-size: 16px;
    line-height: 1;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
  }
  .mobile-menu__link:hover { background: var(--color-bg-2); color: var(--color-ink); }
  .mobile-menu__link [data-icon] {
    width: 19px;
    height: 19px;
    font-size: 19px;
    color: var(--color-ink-3);
    transition: color 0.15s ease;
  }
  .mobile-menu__link:hover [data-icon] { color: var(--color-ink-2); }
  .mobile-menu__link.active { color: var(--color-accent); background: var(--color-accent-soft); }
  .mobile-menu__link.active [data-icon] { color: var(--color-accent); }

  .mobile-menu__footer {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px 16px;
    border-top: 1px solid var(--color-line);
  }
</style>

<script>
  function setupMenu() {
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu || (btn as HTMLElement).dataset.ready) return;
    let open = false;
    const set = (v: boolean) => {
      open = v;
      menu.classList.toggle("open", v);
      btn.setAttribute("aria-expanded", String(v));
      menu.setAttribute("aria-hidden", String(!v));
    };
    btn.addEventListener("click", (e) => { e.stopPropagation(); set(!open); });
    menu.querySelectorAll("a").forEach((l) => l.addEventListener("click", () => set(false)));
    document.addEventListener("click", (e) => {
      if (open && !menu.contains(e.target as Node) && e.target !== btn) set(false);
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && open) set(false); });
    (btn as HTMLElement).dataset.ready = "true";
  }

  function setupSpy() {
    const links = [...document.querySelectorAll<HTMLElement>("[data-spy]")];
    if (!links.length) return;

    // Ids únicos en orden de aparición; cada id puede tener varios enlaces
    // (navbar de escritorio + menú móvil) y todos se marcan a la vez.
    const ids = [...new Set(links.map((l) => l.dataset.spy!))];
    const targets = ids
      .map((id) => ({ id, el: document.getElementById(id) }))
      .filter((t): t is { id: string; el: HTMLElement } => !!t.el);
    if (!targets.length) return;

    // Con true, el hero cuenta como la primera sección y siempre hay una
    // activa. Con false, por encima de la primera sección no se marca ninguna.
    const HIGHLIGHT_FIRST_AT_TOP = true;

    let queued = false;

    function update() {
      queued = false;
      const line = window.scrollY + window.innerHeight * 0.35;

      let currentId: string | null = HIGHLIGHT_FIRST_AT_TOP ? targets[0].id : null;
      for (const t of targets) {
        if (t.el.getBoundingClientRect().top + window.scrollY <= line) currentId = t.id;
      }

      // Al final de la página gana la última sección aunque sea corta y nunca
      // llegue a cruzar la línea.
      const atBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
      if (atBottom) currentId = targets[targets.length - 1].id;

      links.forEach((l) => l.classList.toggle("active", l.dataset.spy === currentId));
    }

    function onScroll() {
      if (queued) return;
      queued = true;
      requestAnimationFrame(update);
    }

    // En cada navegación se vuelve a montar: hay que soltar el listener
    // anterior o se van acumulando.
    const prev = (window as any).__spyCleanup;
    if (prev) prev();
    (window as any).__spyCleanup = () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onScroll);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    update();
  }

  setupMenu();
  setupSpy();
  document.addEventListener("astro:after-swap", () => { setupMenu(); setupSpy(); });
</script>
