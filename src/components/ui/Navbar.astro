---
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import ThemeToggle from "@ui/ThemeToggle.astro";
import LanguagePicker from "@ui/LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { id: "home",      href: lang === "es" ? "/" : "/en",                idx: "00", label: t("nav.home") },
  { id: "work",      href: lang === "es" ? "/work" : "/en/work",       idx: "01", label: t("nav.work") },
  { id: "projects",  href: lang === "es" ? "/projects" : "/en/projects", idx: "02", label: t("nav.projects") },
  { id: "education", href: lang === "es" ? "/education" : "/en/education", idx: "03", label: t("nav.education") },
  { id: "contact",   href: lang === "es" ? "/contact" : "/en/contact", idx: "04", label: t("nav.contact") },
];

const cvHref = lang === "es"
  ? "/assets/documents/davidherrera-spanish.pdf"
  : "/assets/documents/davidherrera-english.pdf";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string): boolean {
  if (href === "/" || href === "/en") return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="nav">
  <div class="nav__inner">
    <a href={lang === "es" ? "/" : "/en"} class="nav__brand" aria-label="David Herrera - Home">
      <b>davidherrera</b><span class="nav__brand-tld">.dev</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-astro-prefetch="hover"
          class={`nav__link ${isActive(item.href) ? "active" : ""}`}
        >
          <span class="idx">{item.idx}</span>{item.label}
        </a>
      ))}
    </nav>

    <div class="nav__utils">
      <LanguagePicker />
      <div class="nav__utils-desktop">
        <ThemeToggle />
        <a
          href={cvHref}
          target="_blank"
          rel="noopener noreferrer"
          class="chip accent nav__cv"
          aria-label={t("nav.cv")}
        >
          <i class="ph-fill ph-file-arrow-down"></i>
          {t("nav.cv")}
        </a>
      </div>
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <i class="ph-fill ph-list" style="font-size: 22px;"></i>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile">
      {navItems.map((item) => (
        <a
          href={item.href}
          data-astro-prefetch
          class={`mobile-menu__link ${isActive(item.href) ? "active" : ""}`}
        >
          <span class="idx">{item.idx}</span>{item.label}
          {isActive(item.href) && <span class="dot" aria-hidden="true"></span>}
        </a>
      ))}
    </nav>
    <div class="mobile-menu__footer">
      <ThemeToggle />
      <a
        href={cvHref}
        target="_blank"
        rel="noopener noreferrer"
        class="chip accent"
      >
        <i class="ph-fill ph-file-arrow-down"></i>
        {t("nav.cv")}
      </a>
    </div>
  </div>
</header>

<style>
  .nav__utils-desktop {
    display: none;
    align-items: center;
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .nav__utils-desktop { display: inline-flex; }
  }

  .mobile-menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    background: transparent;
    border: 0;
    color: var(--color-ink-2);
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
  }
  .mobile-menu-btn:hover { color: var(--color-ink); }

  @media (min-width: 1024px) {
    .mobile-menu-btn { display: none; }
  }

  .mobile-menu__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px;
    border-top: 1.5px dashed var(--color-ink-3);
    flex-wrap: wrap;
  }

  @media (min-width: 1024px) {
    .mobile-menu__footer { display: none; }
  }

  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1.5px dashed var(--color-ink-3);
    transform: translateY(-8px) scaleY(0.98);
    opacity: 0;
    pointer-events: none;
    transform-origin: top;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-menu.open {
    transform: translateY(0) scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-2);
    text-decoration: none;
    border-top: 1.5px dashed var(--color-ink-3);
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .mobile-menu__link:first-child { border-top: 0; }
  .mobile-menu__link:hover,
  .mobile-menu__link:active { background: var(--color-bg-2); color: var(--color-ink); }
  .mobile-menu__link.active { color: var(--color-ink); }

  .mobile-menu__link .idx {
    font-size: 11px;
    color: var(--color-ink-3);
  }

  .mobile-menu__link .dot {
    margin-left: auto;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }
</style>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu || (btn as HTMLElement).dataset.ready) return;

    const links = menu.querySelectorAll("a");
    let isOpen = false;

    function setOpen(open: boolean) {
      isOpen = open;
      menu!.classList.toggle("open", open);
      btn!.setAttribute("aria-expanded", open ? "true" : "false");
      menu!.setAttribute("aria-hidden", open ? "false" : "true");
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!isOpen);
    });

    links.forEach((l) => l.addEventListener("click", () => setOpen(false)));

    document.addEventListener("click", (e) => {
      if (isOpen && !menu!.contains(e.target as Node) && e.target !== btn) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) setOpen(false);
    });

    document.addEventListener("astro:before-preparation", () => setOpen(false));

    (btn as HTMLElement).dataset.ready = "true";
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
