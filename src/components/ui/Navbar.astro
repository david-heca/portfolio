---
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";
import ThemeToggle from "@ui/ThemeToggle.astro";
import LanguagePicker from "@ui/LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = lang === "es" ? "/" : "/en";

const navItems = [
  { id: "about", label: t("nav.about") },
  { id: "work", label: t("nav.work") },
  { id: "projects", label: t("nav.projects") },
  { id: "education", label: t("nav.education") },
  { id: "speaking", label: t("nav.speaking") },
  { id: "contact", label: t("nav.contact") },
];

const cvHref = lang === "es"
  ? "/assets/documents/davidherrera-spanish.pdf"
  : "/assets/documents/davidherrera-english.pdf";
---

<header class="nav">
  <div class="nav__inner">
    <a href={`${home}#top`} class="nav__brand" aria-label="David Herrera">
      david<span>herrera</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {navItems.map((item) => (
        <a href={`#${item.id}`} class="nav__link" data-spy={item.id}>{item.label}</a>
      ))}
    </nav>

    <div class="nav__utils">
      <LanguagePicker />
      <div class="nav__utils-desktop">
        <ThemeToggle />
        <a href={cvHref} target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--sm">
          <Icon name="ph:read-cv-logo-duotone" />
          {t("nav.cv")}
        </a>
      </div>
      <button id="menu-btn" class="menu-btn" aria-label="Menu" aria-expanded="false">
        <Icon name="ph:list-bold" style="font-size: 22px;" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile">
      {navItems.map((item) => (
        <a href={`#${item.id}`} class="mobile-menu__link">{item.label}</a>
      ))}
    </nav>
    <div class="mobile-menu__footer">
      <ThemeToggle />
      <a href={cvHref} target="_blank" rel="noopener noreferrer" class="btn btn--ghost btn--sm">
        <Icon name="ph:read-cv-logo-duotone" />
        {t("nav.cv")}
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 14px 16px;
  }

  .nav__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 8px 8px 22px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-bg) 70%, transparent);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
  }

  .nav__brand {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--color-ink);
    flex-shrink: 0;
  }
  .nav__brand span { color: var(--color-accent); }

  .nav__links {
    display: none;
    gap: 4px;
    align-items: center;
  }
  @media (min-width: 1024px) { .nav__links { display: inline-flex; } }
  .nav__link {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-ink-2);
    padding: 8px 14px;
    border-radius: 999px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav__link:hover { color: var(--color-ink); background: var(--color-bg-2); }
  .nav__link.active { color: var(--color-accent); background: var(--color-accent-soft); }

  .nav__utils { display: inline-flex; align-items: center; gap: 10px; }
  .nav__utils-desktop { display: none; align-items: center; gap: 10px; }
  @media (min-width: 1024px) { .nav__utils-desktop { display: inline-flex; } }

  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: var(--color-ink-2);
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: 999px;
  }
  .menu-btn:hover { background: var(--color-bg-2); color: var(--color-ink); }
  @media (min-width: 1024px) { .menu-btn { display: none; } }

  .mobile-menu {
    position: absolute;
    top: calc(100% - 2px);
    left: 16px;
    right: 16px;
    max-width: 1000px;
    margin: 0 auto;
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .mobile-menu.open { transform: none; opacity: 1; pointer-events: auto; }
  .mobile-menu nav { display: flex; flex-direction: column; padding: 8px; }
  .mobile-menu__link {
    padding: 13px 16px;
    font-size: 16px;
    font-weight: 500;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
  }
  .mobile-menu__link:hover { background: var(--color-bg-2); color: var(--color-accent); }
  .mobile-menu__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-top: 1px solid var(--color-line);
  }
</style>

<script>
  function setupMenu() {
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu || (btn as HTMLElement).dataset.ready) return;
    let open = false;
    const set = (v: boolean) => {
      open = v;
      menu.classList.toggle("open", v);
      btn.setAttribute("aria-expanded", String(v));
      menu.setAttribute("aria-hidden", String(!v));
    };
    btn.addEventListener("click", (e) => { e.stopPropagation(); set(!open); });
    menu.querySelectorAll("a").forEach((l) => l.addEventListener("click", () => set(false)));
    document.addEventListener("click", (e) => {
      if (open && !menu.contains(e.target as Node) && e.target !== btn) set(false);
    });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && open) set(false); });
    (btn as HTMLElement).dataset.ready = "true";
  }

  function setupSpy() {
    const links = document.querySelectorAll<HTMLElement>(".nav__link[data-spy]");
    if (!links.length) return;
    const byId = new Map([...links].map((l) => [l.dataset.spy, l]));
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove("active"));
            byId.get(e.target.id)?.classList.add("active");
          }
        });
      },
      { rootMargin: "-45% 0px -50% 0px" },
    );
    byId.forEach((_, id) => {
      const el = id && document.getElementById(id);
      if (el) obs.observe(el);
    });
  }

  setupMenu();
  setupSpy();
  document.addEventListener("astro:after-swap", () => { setupMenu(); setupSpy(); });
</script>
