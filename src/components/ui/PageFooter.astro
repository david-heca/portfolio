---
import { useTranslations } from "@i18n/utils";
import { Icon } from "astro-icon/components";

export interface Props {
  lang: "es" | "en";
  num: "00" | "01" | "02" | "03" | "04";
}

const { lang, num } = Astro.props;
const t = useTranslations(lang);

const order: Array<{ num: string; href: string; key: string }> = [
  { num: "00", href: lang === "es" ? "/" : "/en",                    key: "home" },
  { num: "01", href: lang === "es" ? "/work" : "/en/work",           key: "work" },
  { num: "02", href: lang === "es" ? "/projects" : "/en/projects",   key: "projects" },
  { num: "03", href: lang === "es" ? "/education" : "/en/education", key: "education" },
  { num: "04", href: lang === "es" ? "/contact" : "/en/contact",     key: "contact" },
];

const currentIdx = order.findIndex((o) => o.num === num);
const next = order[(currentIdx + 1) % order.length];
const prev = order[(currentIdx - 1 + order.length) % order.length];
const year = new Date().getFullYear();

const nextLabel = t(`nav.${next.key}`);
const prevLabel = t(`nav.${prev.key}`);
---

<footer class="footer">
  <div class="footer__inner">
    <div class="meta-row">
      <span>© {year} — David Herrera</span>
      <span class="sep">/</span>
      <a
        href="https://github.com/david-heca/portfolio"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__next"
      >
        <Icon name="ph:github-logo-duotone" style="font-size: 12px;" />
        {t("common.footer.license")}
      </a>
    </div>
    <div class="meta-row">
      <a href={prev.href} class="footer__next" data-astro-prefetch="hover">↑ {prevLabel}</a>
      <span class="accent">{num} / 04</span>
      <a href={next.href} class="footer__next" data-astro-prefetch="hover">{nextLabel} ↓</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: var(--line) dashed var(--color-ink-3);
    margin-top: auto;
    background: var(--color-bg);
  }
  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 18px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--color-ink-2);
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer__inner .meta-row { font-size: 11px; gap: 16px; }
  .footer__inner .accent { color: var(--color-accent); }
  .footer__next {
    color: var(--color-ink-2);
    text-decoration: none;
    transition: color 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .footer__next:hover { color: var(--color-accent); }
</style>
