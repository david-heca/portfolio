---
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="theme-toggle" role="radiogroup" aria-label="Theme">
  <button
    type="button"
    data-theme="light"
    class="theme-toggle__btn"
    role="radio"
    aria-checked="false"
    aria-label={t("theme.light")}
  >
    LIGHT
  </button>
  <button
    type="button"
    data-theme="dark"
    class="theme-toggle__btn"
    role="radio"
    aria-checked="false"
    aria-label={t("theme.dark")}
  >
    DARK
  </button>
</div>

<style>
  .theme-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border: 1px solid var(--color-line);
    border-radius: 2px;
  }

  .theme-toggle__btn {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 4px 8px;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--color-ink-3);
    letter-spacing: 0.04em;
    line-height: 1.2;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .theme-toggle__btn:hover {
    color: var(--color-ink-2);
  }

  .theme-toggle__btn[aria-checked="true"] {
    background: var(--color-ink);
    color: var(--color-bg);
  }
</style>

<script>
  function setupThemeToggle() {
    const root = document.documentElement;
    const wrappers = document.querySelectorAll<HTMLElement>(".theme-toggle");
    if (!wrappers.length) return;

    const THEME_KEY = "color-theme";

    function getStoredTheme(): "light" | "dark" | null {
      const v = localStorage.getItem(THEME_KEY);
      return v === "light" || v === "dark" ? v : null;
    }

    function getResolvedTheme(): "light" | "dark" {
      const stored = getStoredTheme();
      if (stored) return stored;
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }

    function applyTheme(theme: "light" | "dark") {
      if (theme === "dark") root.classList.add("dark");
      else root.classList.remove("dark");
    }

    function setActive(theme: "light" | "dark") {
      document.querySelectorAll<HTMLButtonElement>(".theme-toggle__btn").forEach((b) => {
        const active = b.dataset.theme === theme;
        b.setAttribute("aria-checked", active ? "true" : "false");
      });
    }

    const current = getResolvedTheme();
    applyTheme(current);
    setActive(current);

    wrappers.forEach((wrapper) => {
      if (wrapper.dataset.ready) return;
      wrapper.querySelectorAll<HTMLButtonElement>(".theme-toggle__btn").forEach((b) => {
        b.addEventListener("click", () => {
          const theme = b.dataset.theme as "light" | "dark";
          localStorage.setItem(THEME_KEY, theme);
          applyTheme(theme);
          setActive(theme);
        });
      });
      wrapper.dataset.ready = "true";
    });
  }

  setupThemeToggle();
  document.addEventListener("astro:page-load", setupThemeToggle);
</script>
