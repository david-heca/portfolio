---
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="seg theme-toggle" role="radiogroup" aria-label="Theme">
  <button
    type="button"
    data-theme="light"
    class="theme-toggle__btn"
    role="radio"
    aria-checked="false"
    aria-label={t("theme.light")}
    title={t("theme.light")}
  >
    <i class="ph-duotone ph-sun"></i>
  </button>
  <button
    type="button"
    data-theme="system"
    class="theme-toggle__btn"
    role="radio"
    aria-checked="false"
    aria-label={t("theme.system")}
    title={t("theme.system")}
  >
    <i class="ph-duotone ph-monitor"></i>
  </button>
  <button
    type="button"
    data-theme="dark"
    class="theme-toggle__btn"
    role="radio"
    aria-checked="false"
    aria-label={t("theme.dark")}
    title={t("theme.dark")}
  >
    <i class="ph-duotone ph-moon"></i>
  </button>
</div>

<script>
  type ThemePref = "light" | "dark" | "system";

  function setupThemeToggle() {
    const root = document.documentElement;
    const wrappers = document.querySelectorAll<HTMLElement>(".theme-toggle");
    if (!wrappers.length) return;

    const THEME_KEY = "color-theme";

    function getStoredTheme(): ThemePref {
      const v = localStorage.getItem(THEME_KEY);
      if (v === "light" || v === "dark" || v === "system") return v;
      return "system";
    }

    function resolveTheme(pref: ThemePref): "light" | "dark" {
      if (pref === "system") {
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      }
      return pref;
    }

    function applyTheme(theme: "light" | "dark") {
      if (theme === "dark") root.classList.add("dark");
      else root.classList.remove("dark");
    }

    function setActive(pref: ThemePref) {
      document.querySelectorAll<HTMLButtonElement>(".theme-toggle__btn").forEach((b) => {
        const active = b.dataset.theme === pref;
        b.setAttribute("aria-checked", active ? "true" : "false");
      });
    }

    const currentPref = getStoredTheme();
    applyTheme(resolveTheme(currentPref));
    setActive(currentPref);

    wrappers.forEach((wrapper) => {
      if (wrapper.dataset.ready) return;
      wrapper.querySelectorAll<HTMLButtonElement>(".theme-toggle__btn").forEach((b) => {
        b.addEventListener("click", () => {
          const pref = b.dataset.theme as ThemePref;
          localStorage.setItem(THEME_KEY, pref);
          applyTheme(resolveTheme(pref));
          setActive(pref);
        });
      });
      wrapper.dataset.ready = "true";
    });
  }

  setupThemeToggle();
  document.addEventListener("astro:page-load", setupThemeToggle);
</script>
