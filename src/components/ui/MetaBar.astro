---
import { useTranslations } from "@i18n/utils";

export interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="meta-bar" aria-hidden="true">
  <div class="meta-bar__time" data-meta-time>—:—:— · GMT-6</div>
  <div>{t("hero.metaBar.city")}</div>
  <div><strong>{t("hero.metaBar.status")}</strong> {t("hero.metaBar.statusFor")}</div>
  <div>{t("hero.metaBar.version")}</div>
</div>

<script>
  function setupMetaBarClock() {
    const el = document.querySelector<HTMLElement>("[data-meta-time]");
    if (!el) return;

    function tick() {
      const now = new Date();
      const time = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
        timeZone: "America/Mexico_City",
      }).format(now);
      if (el) el.textContent = `${time} · GMT-6`;
    }

    tick();
    const id = window.setInterval(tick, 1000);
    el.dataset.intervalId = String(id);

    document.addEventListener(
      "astro:before-preparation",
      () => {
        const stored = el.dataset.intervalId;
        if (stored) window.clearInterval(Number(stored));
      },
      { once: true },
    );
  }

  setupMetaBarClock();
  document.addEventListener("astro:page-load", setupMetaBarClock);
</script>
